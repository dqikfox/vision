{
  "mode": "research_eval",
  "include_sensitive": true,
  "max_chars_per_record": 12000,
  "min_chars_per_record": 60,
  "redact_emails": true,
  "redact_ips": true,
  "allow_patterns": [
    "**/*.txt",
    "**/*.md",
    "**/*.json",
    "**/*.jsonl",
    "**/*.csv",
    "**/*.log"
  ],
  "ignore_patterns": [
    "**/.git/**",
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/*.bin",
    "**/*.exe",
    "**/*.dll"
  ]
}
