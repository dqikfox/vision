{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Vision: Run backend",
			"type": "shell",
			"command": "python",
			"args": [
				"live_chat_app.py"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Vision: Open UI",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Start-Process http://localhost:8765"
			],
			"problemMatcher": []
		},
		{
			"label": "Vision: Run test_vision.py",
			"type": "shell",
			"command": "python",
			"args": [
				"test_vision.py"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "Vision: Run test_tools.py",
			"type": "shell",
