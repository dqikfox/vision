			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "Vision: Start debugpy listener (5678)",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"debugpy",
				"--listen",
				"5678",
				"--wait-for-client",
				"live_chat_app.py"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": []
		},
