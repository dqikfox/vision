# Normalize line endings to LF for all text files, regardless of the
# checking-out machine's core.autocrlf setting. Without this, a Windows
# runner/clone with core.autocrlf=true silently converts LF blobs to CRLF
# on checkout, which then fails `ruff format --check .` (pyproject.toml
# pins [tool.ruff.format] line-ending = "lf"). This was the real root
# cause behind CI failing on every PR that touched Python files even when
# the working tree looked correctly formatted locally.
* text=auto eol=lf

# Windows-specific scripts should keep CRLF for native tooling.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files - do not touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.db binary
*.sqlite binary
*.whl binary
