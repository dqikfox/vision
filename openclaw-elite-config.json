{
  "version": "1.0.0",
  "elite": {
    "description": "Elite dev configuration for OpenClaw integration",
    "vision": {
      "backend_url": "USE_ENV_BACKEND_URL",
      "health_endpoint": "/api/health",
      "command_center": "http://localhost:8765/command-center"
    },
    "models": {
      "default": "openclaw/default",
      "fast": "openclaw/gpt-4o-mini",
      "power": "openclaw/claude-sonnet-4",
      "local": "openclaw/ollama-local"
    },
    "cli": {
      "auto_verify": true,
      "auto_start_gateway": true,
      "show_tokens": false,
      "timeout_seconds": 30
    },
    "features": {
      "enable_vision_context": true,
      "enable_metrics": true,
      "enable_session_logging": true,
      "auto_check_updates": true
    }
  }
}
