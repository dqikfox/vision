<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>3D Avatar Test</title>
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module">
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
window.THREE = THREE;
window.GLTFLoader = GLTFLoader;
</script>
<style>
  body {
    margin: 0;
    padding: 0;
    background: #030611;
    color: #fff;
    font-family: monospace;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
  }
  #container {
    width: 600px;
    height: 600px;
    border: 2px solid #4f46e5;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(79,70,229,.4);
  }
  #status {
    margin-top: 20px;
    font-size: 14px;
    color: #06b6d4;
  }
  canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
</head>
<body>
<div id="container">
  <canvas id="avatar3d"></canvas>
</div>
<div id="status">Initializing 3D Avatar...</div>

<script>
let scene, camera, renderer, model, mixer;
let animationId = null;

function init() {
  const canvas = document.getElementById('avatar3d');
  const container = document.getElementById('container');
  const status = document.getElementById('status');

  const width = container.clientWidth;
  const height = container.clientHeight;

  // Scene
  scene = new THREE.Scene();
  scene.background = new THREE.Color(0x030611);

  // Camera
  camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
  camera.position.set(0, 1.2, 3.5);
  camera.lookAt(0, 1, 0);

  // Renderer
  renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true });
  renderer.setSize(width, height);
  renderer.setPixelRatio(window.devicePixelRatio);
  renderer.shadowMap.enabled = true;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.2;

  // Lighting
  const ambientLight = new THREE.AmbientLight(0x4f46e5, 0.5);
  scene.add(ambientLight);

  const keyLight = new THREE.DirectionalLight(0x06b6d4, 1.5);
  keyLight.position.set(3, 4, 2);
  keyLight.castShadow = true;
  scene.add(keyLight);

  const fillLight = new THREE.DirectionalLight(0x4f46e5, 0.8);
  fillLight.position.set(-2, 2, -1);
  scene.add(fillLight);

  const rimLight = new THREE.PointLight(0x22c55e, 1.0, 10);
  rimLight.position.set(0, 2, -2);
  scene.add(rimLight);

  // Load model
  status.textContent = 'Loading 3D model...';
  const loader = new THREE.GLTFLoader();

  loader.load(
    'assets/ultron-avatar.glb',
    function (gltf) {
      model = gltf.scene;

      // Center and scale
      const box = new THREE.Box3().setFromObject(model);
      const center = box.getCenter(new THREE.Vector3());
      const size = box.getSize(new THREE.Vector3());
      const maxDim = Math.max(size.x, size.y, size.z);
      const scale = 2.0 / maxDim;

      model.scale.setScalar(scale);
      model.position.sub(center.multiplyScalar(scale));
      model.position.y = 0;

      // Apply materials
      model.traverse(function (child) {
        if (child.isMesh) {
          child.castShadow = true;
          child.receiveShadow = true;
          if (child.material) {
            child.material.metalness = 0.7;
            child.material.roughness = 0.3;
            child.material.emissive = new THREE.Color(0x4f46e5);
            child.material.emissiveIntensity = 0.2;
          }
        }
      });

      scene.add(model);

      // Setup animations
      if (gltf.animations && gltf.animations.length > 0) {
        mixer = new THREE.AnimationMixer(model);
        const action = mixer.clipAction(gltf.animations[0]);
        action.play();
        status.textContent = `✓ Model loaded! (${gltf.animations.length} animations)`;
      } else {
        status.textContent = '✓ Model loaded! (no animations)';
      }

      console.log('Model loaded:', gltf);
      console.log('Animations:', gltf.animations);
    },
    function (xhr) {
      const percent = (xhr.loaded / xhr.total * 100).toFixed(1);
      status.textContent = `Loading: ${percent}%`;
    },
    function (error) {
      status.textContent = '✗ Error loading model';
      console.error('Error:', error);
      createFallback();
    }
  );

  // Animation loop
  animate();
}

function createFallback() {
  const group = new THREE.Group();

  const headGeo = new THREE.SphereGeometry(0.5, 32, 32);
  const headMat = new THREE.MeshStandardMaterial({
    color: 0x1e3a8a,
    metalness: 0.9,
    roughness: 0.2,
    emissive: 0x4f46e5,
    emissiveIntensity: 0.3
  });
  const head = new THREE.Mesh(headGeo, headMat);
  head.position.y = 1;
  head.castShadow = true;
  group.add(head);

  const eyeGeo = new THREE.SphereGeometry(0.08, 16, 16);
  const eyeMat = new THREE.MeshStandardMaterial({
    color: 0x06b6d4,
    emissive: 0x06b6d4,
    emissiveIntensity: 2
  });

  const leftEye = new THREE.Mesh(eyeGeo, eyeMat);
  leftEye.position.set(-0.15, 1.1, 0.4);
  group.add(leftEye);

  const rightEye = new THREE.Mesh(eyeGeo, eyeMat);
  rightEye.position.set(0.15, 1.1, 0.4);
  group.add(rightEye);

  model = group;
  scene.add(group);
  document.getElementById('status').textContent = '✓ Fallback avatar created';
}

const clock = new THREE.Clock();
function animate() {
  animationId = requestAnimationFrame(animate);

  const delta = clock.getDelta();

  if (mixer) {
    mixer.update(delta);
  }

  if (model) {
    model.rotation.y += 0.005;
    const time = Date.now() * 0.001;
    model.position.y = Math.sin(time * 2) * 0.05;
  }

  renderer.render(scene, camera);
}

// Start when Three.js loads
if (typeof THREE !== 'undefined') {
  init();
} else {
  setTimeout(init, 500);
}
</script>
</body>
</html>
