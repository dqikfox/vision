"""Voice Command Library for Hands-Free Computer Control

Comprehensive library of voice commands for users without hands.
Every computer task should be achievable through voice alone.

For: Your sister and all users needing hands-free operation.
"""

from __future__ import annotations

import logging
import re
from dataclasses import dataclass
from enum import Enum
from typing import Any, Callable

logger = logging.getLogger(__name__)


class CommandCategory(Enum):
    """Categories of voice commands."""
    BASIC = "basic"  # Click, type, open
    NAVIGATION = "navigation"  # Scroll, move, navigate
    WINDOW = "window"  # Minimize, maximize, close
    SYSTEM = "system"  # Volume, settings, shutdown
    WEB = "web"  # Browse, search, navigate web
    TEXT = "text"  # Type, edit, format
    MEDIA = "media"  # Play, pause, volume
    CREATIVE = "creative"  # Draw, design, create
    COMMUNICATION = "communication"  # Email, chat, call
    ACCESSIBILITY = "accessibility"  # Screen reader, magnifier


@dataclass
class VoiceCommand:
    """A voice command that can be executed hands-free."""
    name: str
    category: CommandCategory
    patterns: list[str]  # Multiple ways to say the same thing
    action: str  # Action to execute
    description: str
    examples: list[str]
    requires_confirmation: bool = False  # Destructive actions need confirmation

    def matches(self, text: str) -> bool:
        """Check if text matches this command."""
        text_lower = text.lower().strip()
        return any(re.search(pattern, text_lower) for pattern in self.patterns)


