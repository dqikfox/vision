class VoiceCommandParser:
    """Parse natural language into executable commands."""

    def __init__(self):
        self.commands = VOICE_COMMANDS
        logger.info(f"Loaded {len(self.commands)} voice commands")

    def parse(self, text: str) -> dict[str, Any] | None:
        """Parse voice input into a command.

        Args:
            text: Voice input text

        Returns:
            Command dict or None if no match
        """
        for cmd in self.commands:
            if cmd.matches(text):
                return {
                    "command": cmd.name,
                    "action": cmd.action,
                    "category": cmd.category.value,
                    "text": text,
                    "requires_confirmation": cmd.requires_confirmation,
                    "description": cmd.description
                }

        # No direct match - might be a natural language request
        return {
            "command": "natural_language",
            "action": "llm_interpret",
            "text": text,
            "requires_confirmation": False
        }

    def get_commands_by_category(self, category: CommandCategory) -> list[VoiceCommand]:
        """Get all commands in a category."""
        return [cmd for cmd in self.commands if cmd.category == category]

    def get_all_examples(self) -> dict[str, list[str]]:
        """Get all command examples by category."""
        result = {}
        for category in CommandCategory:
            commands = self.get_commands_by_category(category)
            result[category.value] = []
            for cmd in commands:
                result[category.value].extend(cmd.examples)
        return result


# Singleton parser
_parser: VoiceCommandParser | None = None

def get_voice_parser() -> VoiceCommandParser:
    """Get the singleton voice command parser."""
    global _parser
    if _parser is None:
        _parser = VoiceCommandParser()
    return _parser
