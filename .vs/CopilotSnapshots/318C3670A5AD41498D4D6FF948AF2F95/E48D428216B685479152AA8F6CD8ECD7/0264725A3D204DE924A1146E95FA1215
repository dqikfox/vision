<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>VISION — Universal Accessibility Operator</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module">
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
window.THREE = THREE;
window.GLTFLoader = GLTFLoader;
window.THREE_LOADED = true;
console.log('Three.js and GLTFLoader loaded successfully');
</script>
<style>
/* ═══════ ROOT ═══════ */
:root{
  --bg:#030611;--bg2:#0a1020;
  --p:#4f46e5;--p2:#60a5fa;--p3:#bfdbfe;
  --c:#06b6d4;--c2:#67e8f9;--c3:#cffafe;
  --g:#22c55e;--g2:#86efac;
  --gold:#f59e0b;--gold2:#fde68a;
  --r:#ef4444;--r2:#fecaca;
  --dim:#38506f;
  --tx:#e6f0ff;--tx2:#8ba8c7;
  --glow:rgba(79,70,229,.45);--cglow:rgba(34,211,238,.32);
  --panel-bg:rgba(8,12,28,.74);
  --panel-border:rgba(96,165,250,.18);
  --panel-gloss:rgba(255,255,255,.05);
  --panel-shadow:0 28px 90px rgba(0,0,0,.45);
  --metal:#050913;--metal2:#0c1528;
  --font-ui:'Orbitron',monospace;--font-mono:'Share Tech Mono',monospace;
}

/* High Contrast Mode Variables */
:root.high-contrast {
  --bg:#000000;--bg2:#111111;
  --p:#00ffff;--p2:#00ffff;--p3:#00ffff;
  --c:#ffff00;--c2:#ffff00;--c3:#ffff00;
  --g:#00ff00;--g2:#00ff00;
  --gold:#ffff00;--gold2:#ffff00;
  --r:#ff0000;--r2:#ff0000;
  --dim:#888888;
  --tx:#ffffff;--tx2:#dddddd;
  --glow:rgba(0,255,255,.45);--cglow:rgba(255,255,0,.32);
  --panel-bg:rgba(0,0,0,.9);
  --panel-border:rgba(0,255,255,.5);
  --panel-gloss:rgba(255,255,255,.1);
  --panel-shadow:0 28px 90px rgba(0,0,0,.7);
  --metal:#000000;--metal2:#111111;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg)}
body{
  font-family:var(--font-mono);color:var(--tx);
  background:
    radial-gradient(circle at 20% 20%, rgba(79,70,229,.16), transparent 28%),
    radial-gradient(circle at 82% 14%, rgba(34,211,238,.14), transparent 24%),
    radial-gradient(circle at 50% 100%, rgba(14,165,233,.09), transparent 32%),
    linear-gradient(180deg,#02040b 0%,#050a18 38%,#07101f 100%);
}

/* ═══════ SCAN LINES ═══════ */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:9000;
  background:repeating-linear-gradient(to bottom,rgba(0,0,20,.05) 0,rgba(0,0,20,.05) 1px,transparent 1px,transparent 3px);
  animation:scanPan 12s linear infinite;
}
body::after{
  content:'';position:fixed;inset:-10%;pointer-events:none;z-index:0;
  background:
    radial-gradient(circle at center, rgba(96,165,250,.08), transparent 42%),
    radial-gradient(circle at center, rgba(34,211,238,.05), transparent 58%);
  filter:blur(40px);
}
@keyframes scanPan{0%{background-position:0 0}100%{background-position:0 300px}}

/* ═══════ BG CANVAS ═══════ */
#bgCanvas{position:fixed;inset:0;width:100%;height:100%;z-index:0}

/* ═══════ BOOT SCREEN ═══════ */
#boot{
  position:fixed;inset:0;z-index:9999;background:var(--bg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:28px;
}
#boot::before{
  content:'';position:absolute;
  width:min(720px,86vw);height:min(520px,74vh);
  border-radius:28px;
  background:linear-gradient(180deg,rgba(10,16,36,.84),rgba(5,9,19,.92));
  border:1px solid rgba(96,165,250,.18);
  box-shadow:0 40px 120px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.05);
  backdrop-filter:blur(26px);
}
#boot > *{position:relative}
#boot.out{animation:bootOut .8s ease forwards}
@keyframes bootOut{to{opacity:0;pointer-events:none;visibility:hidden}}
.boot-logo{
  font-family:var(--font-ui);font-size:clamp(48px,7vw,96px);font-weight:900;letter-spacing:.3em;
  background:linear-gradient(135deg,#dbeafe 0%,var(--c2) 32%,var(--p2) 72%,var(--g2) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 40px rgba(96,165,250,.32)) drop-shadow(0 0 90px rgba(34,211,238,.18));
  animation:logoPulse 3s ease-in-out infinite;
}
@keyframes logoPulse{0%,100%{filter:drop-shadow(0 0 24px rgba(96,165,250,.28)) drop-shadow(0 0 60px rgba(34,211,238,.12))}50%{filter:drop-shadow(0 0 48px rgba(96,165,250,.38)) drop-shadow(0 0 100px rgba(34,211,238,.22))}}
.boot-sub{font-family:var(--font-ui);font-size:12px;letter-spacing:.4em;color:var(--tx2)}
.boot-tagline{font-size:13px;color:var(--tx2);letter-spacing:.12em;max-width:480px;text-align:center;line-height:1.8}
.boot-tagline span{color:var(--c3)}
.boot-bar-wrap{width:420px;height:4px;background:rgba(255,255,255,.06);border-radius:999px;overflow:hidden;margin-top:8px;border:1px solid rgba(255,255,255,.05)}
.boot-bar{height:100%;width:0%;border-radius:2px;
  background:linear-gradient(90deg,var(--p2),var(--c2),var(--g2));
  animation:bootLoad 2.4s cubic-bezier(.4,0,.2,1) forwards .3s;
  box-shadow:0 0 12px rgba(96,165,250,.45),0 0 24px rgba(34,211,238,.3)}
@keyframes bootLoad{to{width:100%}}
.boot-lines{font-size:10px;color:var(--dim);line-height:2.2;text-align:center}
.boot-lines .ok{color:var(--g)}
.boot-enter{
  font-family:var(--font-ui);font-size:10px;letter-spacing:.25em;color:var(--p2);
  animation:blink 1.2s ease-in-out infinite;margin-top:8px;cursor:pointer;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}

/* ═══════ MAIN STAGE ═══════ */
#stage{
  position:fixed;inset:0;z-index:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  pointer-events:none;
  padding:124px 28px 196px;
}

/* ═══════ HERO COMMAND DECK ═══════ */
#heroShell{
  position:relative;
  width:min(1120px,94vw);
  min-height:620px;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:86px 42px 112px;
  border-radius:40px;
  background:
    radial-gradient(circle at 18% 18%, rgba(96,165,250,.16), transparent 24%),
    radial-gradient(circle at 84% 18%, rgba(34,211,238,.14), transparent 26%),
    linear-gradient(180deg,rgba(10,16,36,.92),rgba(6,10,22,.86));
  border:1px solid rgba(96,165,250,.24);
  box-shadow:0 52px 160px rgba(0,0,0,.52), inset 0 1px 0 rgba(255,255,255,.05);
  overflow:hidden;
}
#heroShell::before{
  content:'';position:absolute;inset:18px;
  border:1px solid rgba(96,165,250,.08);
  border-radius:28px;
  pointer-events:none;
}
#heroShell::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:
    linear-gradient(90deg,transparent 0,rgba(96,165,250,.06) 50%,transparent 100%),
    repeating-linear-gradient(90deg,transparent 0,transparent 79px,rgba(255,255,255,.018) 80px),
    repeating-linear-gradient(180deg,transparent 0,transparent 79px,rgba(255,255,255,.014) 80px);
  mix-blend-mode:screen;
  opacity:.44;
}
.hero-kicker,.hero-meta{
  position:absolute;top:24px;
  font-family:var(--font-ui);font-size:10px;letter-spacing:.28em;text-transform:uppercase;
}
.hero-kicker{left:30px;color:var(--c2)}
.hero-meta{right:30px;color:var(--p3)}
.hero-stage-grid{
  width:100%;
  display:flex;
  justify-content:center;
  align-items:center;
}
.hero-copy{
  display:none;
}
.hero-title{
  font-family:var(--font-ui);
  font-size:clamp(40px,5vw,72px);
  line-height:.98;
  letter-spacing:.12em;
  color:#eef6ff;
  text-shadow:0 0 32px rgba(96,165,250,.22);
}
.hero-title span{
  display:block;
  color:var(--c2);
  text-shadow:0 0 34px rgba(34,211,238,.24);
}
.hero-lead{
  max-width:56ch;
  font-size:14px;
  line-height:1.9;
  color:var(--tx2);
}
.hero-pill-row{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
}
.hero-pill{
  min-width:164px;
  padding:14px 16px;
  border-radius:18px;
  border:1px solid rgba(96,165,250,.16);
  background:linear-gradient(180deg,rgba(12,18,38,.82),rgba(8,12,25,.72));
  box-shadow:0 18px 40px rgba(0,0,0,.22);
}
.hero-pill-label{
  font-family:var(--font-ui);
  font-size:8px;
  letter-spacing:.2em;
  color:var(--tx2);
  margin-bottom:8px;
}
.hero-pill-value{
  font-family:var(--font-ui);
  font-size:11px;
  letter-spacing:.14em;
  color:var(--p3);
  word-break:break-word;
}
.hero-col{display:flex;flex-direction:column;gap:14px}
.hero-card{
  position:relative;
  padding:18px 18px 17px;
  border-radius:22px;
  background:linear-gradient(180deg,rgba(12,18,38,.78),rgba(8,12,25,.66));
  border:1px solid rgba(96,165,250,.12);
  box-shadow:0 14px 34px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.03);
}
.hero-card::before{
  content:'';position:absolute;top:0;left:18px;right:18px;height:1px;
  background:linear-gradient(90deg,transparent,rgba(103,232,249,.32),transparent);
}
.hero-card-title{
  font-family:var(--font-ui);font-size:9px;letter-spacing:.24em;
  color:var(--p2);margin-bottom:9px;text-transform:uppercase;
}
.hero-card p{
  font-size:12px;line-height:1.75;color:var(--tx2);
}
.hero-chip-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.hero-chip{
  padding:5px 9px;border-radius:999px;
  border:1px solid rgba(96,165,250,.14);
  background:rgba(255,255,255,.03);
  font-family:var(--font-ui);font-size:8px;letter-spacing:.12em;color:var(--tx2);
}
.hero-chip.accent{border-color:rgba(34,211,238,.24);color:var(--c2)}
.hero-chip.good{border-color:rgba(34,197,94,.22);color:var(--g2)}

/* ═══════ HERO ORB AREA ═══════ */
#hero{
  position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;
  pointer-events:none;
  flex-shrink:0;
  min-height:420px;
}
.hero-avatar-stage{
  width:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  min-height:440px;
}
.hero-avatar-backdrop{
  position:absolute;
  inset:80px 80px 56px;
  border-radius:44px;
  background:
    radial-gradient(circle at 50% 18%, rgba(34,211,238,.22), transparent 34%),
    radial-gradient(circle at 50% 72%, rgba(79,70,229,.22), transparent 46%),
    linear-gradient(180deg, rgba(7,11,24,.52), rgba(5,8,18,.16));
  filter:blur(12px);
}
.hero-avatar-frame{
  position:relative;
  width:min(560px,80vw);
  aspect-ratio:1/1.14;
  border-radius:40px;
  overflow:hidden;
  border:1px solid rgba(103,232,249,.3);
  background:
    linear-gradient(180deg, rgba(10,14,32,.72), rgba(5,9,18,.94)),
    radial-gradient(circle at top, rgba(103,232,249,.12), transparent 44%);
  box-shadow:
    0 42px 110px rgba(0,0,0,.5),
    0 0 0 1px rgba(96,165,250,.12),
    inset 0 1px 0 rgba(255,255,255,.06),
    0 0 40px rgba(79,70,229,.16);
  z-index:2;
}
.hero-avatar-frame::before{
  content:'';
  position:absolute;
  inset:12px;
  border-radius:24px;
  border:1px solid rgba(255,255,255,.08);
  pointer-events:none;
}
.hero-avatar-frame::after{
  content:'';
  position:absolute;
  left:0;right:0;bottom:0;height:30%;
  background:linear-gradient(180deg,transparent,rgba(3,6,17,.82));
  pointer-events:none;
}
#heroAvatar{
  width:100%;
  height:100%;
  display:block;
  transition:transform .5s ease, filter .5s ease;
}
#heroAvatar.canvas-3d{
  object-fit:unset;
  object-position:unset;
  filter:none;
  transform:none;
}
.hero-avatar-stage #orbCanvas{
  position:absolute;
  inset:50%;
  transform:translate(-50%,-50%);
  width:520px;
  height:520px;
  opacity:.18;
  mix-blend-mode:screen;
}
.hero-status-stack{
  position:absolute;
  left:18px;
  right:18px;
  bottom:20px;
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:10px;
  z-index:2;
}
.hero-status-card{
  padding:12px 14px;
  border-radius:16px;
  border:1px solid rgba(96,165,250,.16);
  background:rgba(5,9,18,.7);
  backdrop-filter:blur(12px);
  box-shadow:0 16px 34px rgba(0,0,0,.24);
}
.hero-status-label{
  font-family:var(--font-ui);
  font-size:8px;
  letter-spacing:.18em;
  color:var(--tx2);
  margin-bottom:6px;
}
.hero-status-value{
  font-family:var(--font-ui);
  font-size:11px;
  letter-spacing:.12em;
  color:var(--tx);
  word-break:break-word;
}
.hero-status-note{
  margin-top:4px;
  font-size:10px;
  color:var(--tx2);
  line-height:1.5;
}
#orbCanvas{
  width:320px;height:320px;
  filter:drop-shadow(0 0 60px rgba(29,78,216,.8)) drop-shadow(0 0 120px rgba(29,78,216,.3));
  transition:filter .6s ease;
}
#orbCanvas.speaking{filter:drop-shadow(0 0 60px var(--g)) drop-shadow(0 0 120px rgba(34,197,94,.4))}
#orbCanvas.thinking{filter:drop-shadow(0 0 60px var(--gold)) drop-shadow(0 0 120px rgba(245,158,11,.5))}
#orbCanvas.listening{filter:drop-shadow(0 0 60px var(--c)) drop-shadow(0 0 100px rgba(6,182,212,.4))}

/* State label floating under orb */
#stateLabel{
  font-family:var(--font-ui);font-size:11px;letter-spacing:.35em;
  color:var(--p2);
  transition:color .4s,text-shadow .4s;
  text-align:center;
  pointer-events:none;
}
.hero-footer{
  position:absolute;left:50%;bottom:28px;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:6px;
}
#heroShell[data-runtime-state="thinking"] .hero-avatar-frame{
  border-color:rgba(245,158,11,.5);
  box-shadow:0 34px 90px rgba(0,0,0,.44),0 0 30px rgba(245,158,11,.18);
}
#heroShell[data-runtime-state="speaking"] .hero-avatar-frame{
  border-color:rgba(34,197,94,.5);
  box-shadow:0 34px 90px rgba(0,0,0,.44),0 0 34px rgba(34,197,94,.2);
}
#heroShell[data-runtime-state="listening"] .hero-avatar-frame,
#heroShell[data-runtime-state="recording"] .hero-avatar-frame{
  border-color:rgba(34,211,238,.54);
  box-shadow:0 34px 90px rgba(0,0,0,.44),0 0 34px rgba(34,211,238,.22);
}
#heroShell[data-runtime-state="speaking"] #heroAvatar{
  transform:scale(1.045);
  filter:contrast(1.1) saturate(1.16) drop-shadow(0 0 28px rgba(34,197,94,.14));
}
#heroShell[data-runtime-state="thinking"] #heroAvatar{
  filter:contrast(1.08) saturate(1.14) hue-rotate(-8deg);
}

/* Orbiting data rings */
.orbit-ring{
  position:absolute;border-radius:50%;border:1px solid;
  animation:spinRing linear infinite;opacity:.35;
  pointer-events:none;
}
.ring1{width:360px;height:360px;top:50%;left:50%;transform:translate(-50%,-50%);
  border-color:rgba(29,78,216,.45);animation-duration:18s}
.ring2{width:420px;height:420px;top:50%;left:50%;transform:translate(-50%,-50%);
  border-color:rgba(6,182,212,.25);animation-duration:28s;animation-direction:reverse}
.ring3{width:490px;height:490px;top:50%;left:50%;transform:translate(-50%,-50%);
  border-color:rgba(245,158,11,.18);animation-duration:42s}
@keyframes spinRing{to{transform:translate(-50%,-50%) rotate(360deg)}}

/* Ring dots */
.ring-dot{
  position:absolute;width:6px;height:6px;border-radius:50%;
  top:0;left:50%;transform:translateX(-50%) translateY(-3px);
}
.ring1 .ring-dot{background:var(--p2);box-shadow:0 0 8px var(--p)}
.ring2 .ring-dot{background:var(--c2);box-shadow:0 0 8px var(--c)}
.ring3 .ring-dot{background:var(--gold);box-shadow:0 0 8px var(--gold)}

@media (max-width: 1100px){
  #heroShell{
    width:min(1000px,95vw);
    padding:80px 28px 104px;
  }
}
@media (max-width: 760px){
  #stage{padding:120px 16px 198px}
  #heroShell{
    min-height:auto;
    padding:78px 18px 96px;
    border-radius:28px;
  }
  .hero-avatar-stage #orbCanvas{width:320px;height:320px}
  .hero-avatar-frame{width:min(100%,380px);border-radius:28px}
  .ring1{width:300px;height:300px}
  .ring2{width:344px;height:344px}
  .ring3{width:390px;height:390px}
}

/* ═══════ INPUT BAR — bottom center, always visible ═══════ */
#inputBar{
  position:fixed;bottom:28px;left:50%;transform:translateX(-50%);
  width:min(860px,90vw);z-index:100;pointer-events:all;
  display:flex;align-items:center;gap:14px;
}
#inputWrap{
  flex:1;display:flex;align-items:center;
  background:linear-gradient(180deg,rgba(7,10,24,.88),rgba(9,14,30,.8));
  border:1px solid rgba(96,165,250,.22);
  border-radius:22px;padding:10px 12px 10px 22px;
  backdrop-filter:blur(22px);
  box-shadow:0 0 0 1px rgba(255,255,255,.03),0 18px 60px rgba(0,0,0,.42),inset 0 1px 0 rgba(255,255,255,.04);
  transition:border-color .3s,box-shadow .3s;
}
#inputWrap:focus-within{
  border-color:rgba(96,165,250,.55);
  box-shadow:0 0 0 1px rgba(96,165,250,.18),0 18px 60px rgba(0,0,0,.48),0 0 36px rgba(96,165,250,.12),inset 0 1px 0 rgba(255,255,255,.05);
}
#textInput{
  flex:1;background:none;border:none;outline:none;
  font-family:var(--font-mono);font-size:14px;color:var(--tx);
  padding:10px 8px;
}
#textInput::placeholder{color:var(--dim)}
.input-icon-btn{
  width:46px;height:46px;border-radius:16px;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:18px;
  transition:all .25s;background:transparent;color:var(--tx2);flex-shrink:0;
}
.input-icon-btn:hover{color:var(--tx);background:rgba(255,255,255,.08)}
.input-send-btn{
  width:58px;height:58px;border-radius:20px;border:none;cursor:pointer;
  background:linear-gradient(135deg,var(--p),var(--c));
  display:flex;align-items:center;justify-content:center;font-size:18px;
  box-shadow:0 14px 32px rgba(0,0,0,.35),0 0 22px rgba(96,165,250,.22);
  transition:all .25s;flex-shrink:0;color:#000;
  clip-path:none;
}
.input-send-btn:hover{transform:translateY(-1px) scale(1.04);box-shadow:0 18px 40px rgba(0,0,0,.42),0 0 30px rgba(96,165,250,.34)}
.input-send-btn:active{transform:scale(.95)}

/* ═══════ EDGE PANELS ═══════ */
.edge-panel{
  position:fixed;z-index:500;pointer-events:all;
  display:flex;
}

/* LEFT PANEL — Console/Chat */
#panelLeft{
  left:0;top:0;bottom:0;width:400px;
  flex-direction:row;
  transform:translateX(calc(-100% + 44px));
  transition:transform .35s cubic-bezier(.4,0,.2,1);
}
#panelLeft:hover,#panelLeft.pinned{transform:translateX(0)}
.panel-tab-left{
  width:44px;height:100%;flex-shrink:0;cursor:pointer;
  background:linear-gradient(180deg,rgba(10,16,36,.96),rgba(8,12,26,.88));border-right:1px solid var(--panel-border);
  display:flex;align-items:center;justify-content:center;
  writing-mode:vertical-rl;text-orientation:mixed;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.3em;
  color:var(--p2);text-transform:uppercase;
  border-radius:0 18px 18px 0;
  box-shadow:8px 0 28px rgba(0,0,0,.28);
  user-select:none;
  gap:0;
}
.panel-tab-left .tab-icon{writing-mode:initial;font-size:14px;margin-bottom:8px}

/* RIGHT PANEL — Actions */
#panelRight{
  right:0;top:0;bottom:0;width:384px;
  flex-direction:row-reverse;
  transform:translateX(calc(100% - 44px));
  transition:transform .35s cubic-bezier(.4,0,.2,1);
}
#panelRight:hover,#panelRight.pinned{transform:translateX(0)}
.panel-tab-right{
  width:44px;height:100%;flex-shrink:0;cursor:pointer;
  background:linear-gradient(180deg,rgba(10,16,36,.96),rgba(8,12,26,.88));border-left:1px solid var(--panel-border);
  display:flex;align-items:center;justify-content:center;
  writing-mode:vertical-lr;text-orientation:mixed;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.3em;
  color:var(--c2);text-transform:uppercase;
  border-radius:18px 0 0 18px;
  box-shadow:-8px 0 28px rgba(0,0,0,.28);
  user-select:none;transform:rotate(180deg);
}
.panel-tab-right .tab-icon{writing-mode:initial;font-size:14px;margin-bottom:8px;transform:rotate(180deg)}

/* TOP PANEL — Settings */
#panelTop{
  top:0;left:0;right:0;height:368px;
  flex-direction:column;
  transform:translateY(calc(-100% + 44px));
  transition:transform .35s cubic-bezier(.4,0,.2,1);
}
#panelTop:hover,#panelTop.pinned{transform:translateY(0)}
.panel-tab-top{
  height:44px;width:100%;flex-shrink:0;cursor:pointer;
  background:linear-gradient(180deg,rgba(10,16,36,.96),rgba(8,12,26,.88));border-bottom:1px solid var(--panel-border);
  display:flex;align-items:center;justify-content:center;gap:16px;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.3em;color:var(--gold);
  box-shadow:0 10px 28px rgba(0,0,0,.28);user-select:none;
}

/* PANEL BODY SHARED */
.panel-body{
  flex:1;overflow:hidden;
  background:linear-gradient(180deg,var(--panel-bg),rgba(7,11,24,.82));
  backdrop-filter:blur(28px);
  display:flex;flex-direction:column;
  border:1px solid var(--panel-border);
  box-shadow:var(--panel-shadow), inset 0 1px 0 var(--panel-gloss);
}
#panelLeft .panel-body{border-radius:0 4px 4px 0;border-left:none}
#panelRight .panel-body{border-radius:4px 0 0 4px;border-right:none}
#panelTop .panel-body{border-radius:0 0 4px 4px;border-top:none}

.panel-header{
  padding:16px 20px 12px;border-bottom:1px solid rgba(255,255,255,.05);
  font-family:var(--font-ui);font-size:10px;letter-spacing:.25em;
  display:flex;align-items:center;gap:10px;flex-shrink:0;
  color:#d8e8ff;
  background:linear-gradient(180deg,rgba(255,255,255,.03),transparent);
}
.panel-scroll{flex:1;overflow-y:auto;padding:12px 14px;scrollbar-width:thin;scrollbar-color:var(--dim) transparent}
.panel-scroll::-webkit-scrollbar{width:3px}
.panel-scroll::-webkit-scrollbar-thumb{background:var(--dim);border-radius:2px}

/* ═══════ CONSOLE MESSAGES ═══════ */
.msg{display:flex;gap:10px;margin-bottom:14px;animation:msgIn .3s ease}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.msg-avatar{
  width:30px;height:30px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:13px;
}
.msg-avatar.ai{background:linear-gradient(135deg,var(--p),var(--p2));box-shadow:0 0 12px rgba(29,78,216,.5);color:#000}
.msg-avatar.usr{background:rgba(6,182,212,.2);border:1px solid rgba(6,182,212,.3)}
.msg-role{font-family:var(--font-ui);font-size:8px;letter-spacing:.2em;color:var(--tx2);margin-bottom:4px}
.msg-bubble{
  background:rgba(11,18,34,.78);border:1px solid rgba(96,165,250,.1);
  border-radius:0 16px 16px 16px;padding:11px 14px;
  font-size:13px;line-height:1.65;color:var(--tx);
  max-width:260px;word-wrap:break-word;
  box-shadow:0 12px 32px rgba(0,0,0,.2);
}
.msg-user .msg-bubble{
  background:linear-gradient(180deg,rgba(79,70,229,.18),rgba(37,99,235,.1));border-color:rgba(96,165,250,.18);
  border-radius:16px 0 16px 16px;color:var(--p3);
}
.msg-user{flex-direction:row-reverse}
.msg-system .msg-bubble{
  background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.15);
  color:var(--gold2);font-size:11px;border-radius:8px;max-width:100%;
}
.typing-dots{display:flex;gap:5px;padding:10px 14px}
.t-dot{width:6px;height:6px;border-radius:50%;background:var(--p2);
  animation:typeDot 1.2s ease-in-out infinite}
.t-dot:nth-child(2){animation-delay:.2s}.t-dot:nth-child(3){animation-delay:.4s}
@keyframes typeDot{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}

/* ═══════ ACTION BUTTONS ═══════ */
.action-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;padding:4px 0}
.act-btn{
  background:linear-gradient(180deg,rgba(255,255,255,.04),rgba(255,255,255,.02));border:1px solid rgba(96,165,250,.12);
  border-radius:16px;padding:13px 14px;cursor:pointer;
  font-family:var(--font-mono);font-size:12px;color:var(--tx2);
  text-align:left;transition:all .2s;display:flex;align-items:center;gap:7px;
  box-shadow:0 10px 28px rgba(0,0,0,.16), inset 0 1px 0 rgba(255,255,255,.03);
}
.act-btn:hover{background:linear-gradient(180deg,rgba(79,70,229,.16),rgba(14,165,233,.08));border-color:rgba(96,165,250,.28);color:var(--p3);transform:translateY(-1px)}
.act-btn .act-ico{font-size:14px}
.act-result{
  margin-top:10px;padding:10px;border-radius:4px;font-size:11px;
  background:rgba(16,185,129,.05);border:1px solid rgba(16,185,129,.15);
  color:var(--g2);white-space:pre-wrap;word-break:break-all;line-height:1.6;
  min-height:60px;
}
.section-label{
  font-family:var(--font-ui);font-size:8px;letter-spacing:.25em;
  color:var(--dim);margin:12px 0 6px;text-transform:uppercase;
  color:rgba(29,78,216,.4);
}

/* ═══════ SETTINGS PANEL TOP ═══════ */
.cfg-grid{display:grid;grid-template-columns:1.15fr 1.15fr .9fr;gap:20px;padding:18px}
.cfg-block{display:flex;flex-direction:column;gap:8px}
.cfg-lbl{font-family:var(--font-ui);font-size:8px;letter-spacing:.25em;color:rgba(29,78,216,.5);margin-bottom:2px}
.radio-row{display:flex;gap:8px;flex-wrap:wrap}
.r-opt{
  padding:8px 13px;border-radius:12px;cursor:pointer;font-size:10px;
  border:1px solid rgba(29,78,216,.15);background:rgba(255,255,255,.02);
  color:var(--tx2);transition:all .2s;font-family:var(--font-ui);letter-spacing:.1em;
}
.r-opt.on{background:rgba(29,78,216,.18);border-color:var(--p);color:var(--p3)}
.r-opt.on-c{background:rgba(6,182,212,.15);border-color:var(--c);color:var(--c3)}
.voice-provider-summary{
  display:flex;
  align-items:center;
  gap:10px;
  margin-top:4px;
  margin-bottom:2px;
}
.voice-provider-copy{
  min-width:0;
  display:flex;
  flex-direction:column;
  gap:3px;
}
.voice-provider-title{
  font-family:var(--font-ui);
  font-size:8px;
  letter-spacing:.16em;
  color:var(--p3);
}
.voice-provider-note{
  font-size:10px;
  color:var(--tx2);
  line-height:1.45;
}
.voice-load-hint{
  font-family:var(--font-ui);
  font-size:8px;
  color:var(--dim);
  margin-top:6px;
  letter-spacing:.1em;
}
.key-row{display:flex;gap:6px}
.key-inp{
  flex:1;background:rgba(29,78,216,.04);border:1px solid rgba(29,78,216,.15);
  border-radius:4px;padding:7px 12px;color:var(--tx);font-size:11px;
  font-family:var(--font-mono);outline:none;
}
.key-inp:focus{border-color:var(--p);box-shadow:0 0 0 2px rgba(29,78,216,.12)}
.key-save{
  padding:7px 14px;border-radius:4px;border:none;cursor:pointer;
  background:rgba(29,78,216,.2);color:var(--p3);font-family:var(--font-ui);
  font-size:9px;letter-spacing:.15em;transition:all .2s;
}
.key-save:hover{background:rgba(29,78,216,.4)}
.tts-rate-row{display:flex;align-items:center;gap:10px;font-size:11px}
input[type=range]{-webkit-appearance:none;flex:1;height:3px;border-radius:2px;
  background:rgba(29,78,216,.15);outline:none}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;
  border-radius:50%;background:var(--p2);cursor:pointer;box-shadow:0 0 8px var(--p)}

/* ═══════ STATUS RING (HUD) ═══════ */
#hud{
  position:fixed;top:16px;left:50%;transform:translateX(-50%);
  z-index:200;pointer-events:none;
  display:flex;align-items:center;gap:20px;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.2em;
  background:linear-gradient(180deg,rgba(10,16,36,.86),rgba(8,13,29,.78));backdrop-filter:blur(16px);
  border:1px solid rgba(96,165,250,.16);border-radius:18px;
  padding:10px 22px;
  box-shadow:0 20px 48px rgba(0,0,0,.32), inset 0 1px 0 rgba(255,255,255,.04);
}
.hud-dot{width:6px;height:6px;border-radius:50%;background:var(--dim);transition:all .4s}
.hud-dot.on{background:var(--g2);box-shadow:0 0 8px var(--g)}
.hud-item{display:flex;align-items:center;gap:6px;color:var(--tx2)}
.hud-item span{color:var(--p2)}
#wsHudDot.on{background:var(--g2)}.wsHudDot.off{background:var(--r)}

/* ═══════ COMPONENT STATUS STRIP ═══════ */
#compStatus{
  position:fixed;top:56px;left:50%;transform:translateX(-50%);
  z-index:199;pointer-events:none;
  display:flex;align-items:center;gap:10px;
  font-family:var(--font-ui);font-size:8px;letter-spacing:.15em;
  background:linear-gradient(180deg,rgba(10,16,36,.78),rgba(8,13,29,.68));backdrop-filter:blur(14px);
  border:1px solid rgba(96,165,250,.12);border-radius:14px;
  padding:7px 16px;
  box-shadow:0 16px 40px rgba(0,0,0,.26);
}
.comp-item{display:flex;align-items:center;gap:5px;color:rgba(232,213,163,.4)}
.comp-led{width:5px;height:5px;border-radius:50%;background:#333;transition:all .5s;flex-shrink:0}
.comp-led.ok{background:var(--g2);box-shadow:0 0 6px var(--g)}
.comp-led.warn{background:var(--gold);box-shadow:0 0 6px var(--gold)}
.comp-led.off{background:var(--r);box-shadow:0 0 4px rgba(239,68,68,.4)}

/* ═══════ CORNER BUTTONS ═══════ */
#cornerBL{
  position:fixed;bottom:95px;left:52px;z-index:200;
  display:flex;flex-direction:column;gap:8px;pointer-events:all;
}
#cornerBR{
  position:fixed;bottom:95px;right:52px;z-index:200;
  display:flex;flex-direction:column;gap:8px;pointer-events:all;align-items:flex-end;
}
.corner-btn{
  width:56px;height:56px;border-radius:18px;border:1px solid rgba(96,165,250,.18);
  background:linear-gradient(180deg,rgba(8,12,26,.9),rgba(9,15,32,.82));backdrop-filter:blur(16px);
  display:flex;align-items:center;justify-content:center;font-size:16px;
  cursor:pointer;transition:all .25s;color:var(--tx2);
  box-shadow:0 12px 30px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.04);
  clip-path:none;
}
.corner-btn:hover{border-color:var(--p2);color:var(--p3);box-shadow:0 16px 34px rgba(0,0,0,.4),0 0 24px rgba(96,165,250,.22);transform:translateY(-1px)}
.corner-btn.active{border-color:var(--r);color:var(--r);box-shadow:0 0 16px rgba(239,68,68,.4)}
.corner-btn.mode-op{border-color:var(--c);color:var(--c2)}
.corner-btn-lbl{font-family:var(--font-ui);font-size:8px;letter-spacing:.15em;
  color:var(--tx2);text-align:center;margin-top:2px}

/* ═══════ MODEL BADGE ═══════ */
#modelBadge{
  position:fixed;top:16px;right:80px;z-index:200;pointer-events:all;
  font-family:var(--font-ui);font-size:10px;letter-spacing:.12em;
  background:linear-gradient(135deg,rgba(79,70,229,.18),rgba(6,182,212,.12)),
              linear-gradient(180deg,rgba(10,16,36,.95),rgba(8,13,28,.9));
  backdrop-filter:blur(16px);
  border:1px solid rgba(96,165,250,.35);border-radius:20px;
  padding:9px 18px;color:var(--p3);cursor:pointer;
  transition:all .25s;
  clip-path:none;
  box-shadow:0 8px 32px rgba(0,0,0,.4),0 0 0 1px rgba(96,165,250,.1),inset 0 1px 0 rgba(255,255,255,.08);
  display:flex;align-items:center;gap:10px;
}
#modelBadge::before{
  content:'';width:8px;height:8px;border-radius:50%;
  background:var(--g2);box-shadow:0 0 8px var(--g),0 0 16px var(--g);
  animation:modelPulse 2s ease-in-out infinite;
}
#modelBadge:hover{
  border-color:var(--p2);
  box-shadow:0 16px 38px rgba(0,0,0,.38),0 0 24px rgba(96,165,250,.22),0 0 0 1px rgba(96,165,250,.2);
  transform:translateY(-1px);
}
#modelBadge.no-model::before{
  background:var(--gold);box-shadow:0 0 8px var(--gold);
  animation:none;
}
@keyframes modelPulse{
  0%,100%{opacity:1;transform:scale(1)}
  50%{opacity:.6;transform:scale(.85)}
}

#modelControlPanel{
  position:fixed;top:56px;right:16px;z-index:200;pointer-events:all;
  width:min(470px,calc(100vw - 32px));
  background:linear-gradient(135deg,rgba(79,70,229,.12),rgba(6,182,212,.08)),
              linear-gradient(180deg,rgba(10,16,36,.96),rgba(8,13,28,.92));
  backdrop-filter:blur(18px);
  border:1px solid rgba(96,165,250,.28);
  border-radius:18px;
  padding:12px 14px;
  box-shadow:0 16px 42px rgba(0,0,0,.45),0 0 0 1px rgba(96,165,250,.08),inset 0 1px 0 rgba(255,255,255,.06);
  display:flex;flex-direction:column;gap:10px;
}
.model-panel-head{
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.22em;color:var(--p2);
}
.model-panel-live{
  display:grid;grid-template-columns:1fr 1.25fr;gap:8px;
}
.model-live-card{
  min-width:0;
  padding:10px 12px;border-radius:12px;
  border:1px solid rgba(96,165,250,.14);
  background:rgba(4,8,20,.62);
}
.model-live-label{
  font-family:var(--font-ui);font-size:8px;letter-spacing:.18em;color:var(--tx2);
  margin-bottom:4px;
}
.model-live-value{
  font-family:var(--font-mono);font-size:12px;color:var(--tx);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.model-selector-grid{
  display:grid;grid-template-columns:150px minmax(0,1fr) auto;gap:8px;align-items:end;
}
.model-select-wrap{
  display:flex;flex-direction:column;gap:4px;min-width:0;
}
.model-select-label{
  font-family:var(--font-ui);font-size:8px;letter-spacing:.16em;color:var(--tx2);
}
.model-select{
  width:100%;
  background:rgba(29,78,216,.08);
  border:1px solid rgba(96,165,250,.2);
  border-radius:10px;
  color:var(--tx);
  padding:10px 12px;
  font-size:12px;
  font-family:var(--font-mono);
  outline:none;
}
.model-select:focus{
  border-color:var(--p2);
  box-shadow:0 0 0 1px rgba(96,165,250,.18),0 0 18px rgba(96,165,250,.16);
}
.model-select:disabled{opacity:.65;cursor:not-allowed}
.model-panel-btn{
  height:42px;
  padding:0 16px;border-radius:12px;border:1px solid rgba(96,165,250,.2);
  background:rgba(29,78,216,.14);color:var(--p3);
  font-family:var(--font-ui);font-size:9px;letter-spacing:.14em;
  cursor:pointer;transition:all .2s;
}
.model-panel-btn:hover{
  border-color:var(--p2);
  box-shadow:0 0 18px rgba(96,165,250,.15);
}
.model-panel-note{
  font-family:var(--font-ui);font-size:8px;letter-spacing:.12em;color:var(--tx2);
}
@media (max-width: 900px){
  #modelControlPanel{
    top:104px;left:16px;right:16px;width:auto;
  }
  .model-panel-live,
  .model-selector-grid{
    grid-template-columns:1fr;
  }
}

#commandCenterBadge{
  position:fixed;top:16px;right:232px;z-index:200;pointer-events:all;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.15em;text-decoration:none;
  background:linear-gradient(180deg,rgba(10,16,36,.88),rgba(8,13,28,.82));backdrop-filter:blur(16px);
  border:1px solid rgba(34,211,238,.2);border-radius:16px;
  padding:7px 14px;color:var(--c2);cursor:pointer;
  transition:all .25s;
  clip-path:none;
}
#commandCenterBadge:hover{border-color:var(--c2);box-shadow:0 16px 38px rgba(0,0,0,.38),0 0 24px rgba(34,211,238,.2)}

#systemMapBadge{
  position:fixed;top:16px;right:390px;z-index:200;pointer-events:all;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.15em;
  background:rgba(7,11,19,.9);backdrop-filter:blur(12px);
  border:1px solid rgba(45,212,191,.3);border-radius:4px;
  padding:7px 14px;color:#5eead4;cursor:pointer;
  transition:all .25s;
  clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));
}
#systemMapBadge:hover{border-color:#2dd4bf;box-shadow:0 16px 38px rgba(0,0,0,.38),0 0 24px rgba(45,212,191,.24)}

/* ═══════ EQUALIZER VISUALIZER ═══════ */
#equalizer{
  position:fixed;bottom:90px;left:50%;transform:translateX(-50%);
  width:220px;z-index:150;pointer-events:none;
  display:flex;align-items:flex-end;gap:3px;height:28px;
}
.eq-bar{
  flex:1;border-radius:1px 1px 0 0;
  background:linear-gradient(to top,var(--p),var(--p2));
  transition:height .08s ease;min-height:2px;
  box-shadow:0 0 4px rgba(29,78,216,.4);
}
.eq-bar.hi{background:linear-gradient(to top,var(--c),var(--c2));box-shadow:0 0 6px rgba(6,182,212,.6)}
.eq-bar.peak{background:linear-gradient(to top,var(--r),#ff8888);box-shadow:0 0 8px rgba(239,68,68,.8)}

/* ═══════ METRICS PANEL ═══════ */
#metricsPanel{
  display:none; /* moved into right panel SYSTEM tab */
}
.metric-row{margin-bottom:11px}
.metric-lbl{
  font-family:var(--font-ui);font-size:7px;letter-spacing:.2em;
  color:rgba(29,78,216,.5);margin-bottom:3px;display:flex;justify-content:space-between;
}
.metric-lbl span{color:var(--p2)}
.metric-bar-bg{
  height:3px;background:rgba(29,78,216,.1);border-radius:1px;overflow:hidden;
}
.metric-bar-fill{
  height:100%;border-radius:1px;background:linear-gradient(90deg,var(--p),var(--p2));
  transition:width .8s ease;
  box-shadow:0 0 4px var(--p);
}
.metric-bar-fill.warn{background:linear-gradient(90deg,var(--gold),#ff0)}
.metric-bar-fill.crit{background:linear-gradient(90deg,var(--r),#ff8888)}

/* ═══════ SCREENSHOT VIEWER ═══════ */
#screenshotModal{
  position:fixed;inset:0;z-index:800;background:rgba(2,1,0,.9);
  display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(8px);
}
#screenshotModal.open{display:flex}
#screenshotImg{max-width:90vw;max-height:85vh;border-radius:4px;
  border:1px solid var(--panel-border);box-shadow:0 0 60px rgba(29,78,216,.25)}
.modal-close{
  position:absolute;top:20px;right:24px;
  width:40px;height:40px;border-radius:4px;
  background:rgba(29,78,216,.08);border:1px solid rgba(29,78,216,.2);
  cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;
  color:var(--tx2);transition:all .2s;
}
.modal-close:hover{background:rgba(239,68,68,.2);color:var(--r);border-color:var(--r)}

/* ═══════ MODEL PICKER MODAL ═══════ */
#pickerModal{
  position:fixed;inset:0;z-index:900;background:rgba(2,1,0,.88);
  display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(10px);
}
#pickerModal.open{display:flex}
.picker-box{
  width:min(640px,92vw);max-height:80vh;
  background:rgba(6,5,0,.97);border:1px solid var(--panel-border);
  border-radius:4px;display:flex;flex-direction:column;
  box-shadow:0 0 60px rgba(29,78,216,.15),0 40px 80px rgba(0,0,0,.7);
  overflow:hidden;
}
.picker-hdr{
  padding:18px 22px;border-bottom:1px solid rgba(29,78,216,.1);
  font-family:var(--font-ui);font-size:11px;letter-spacing:.25em;color:var(--p2);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.picker-body{overflow-y:auto;flex:1;scrollbar-width:thin;scrollbar-color:var(--dim) transparent}
.picker-body::-webkit-scrollbar{width:4px}
.picker-body::-webkit-scrollbar-thumb{background:var(--dim);border-radius:2px}
.prov-section{padding:14px 20px;border-bottom:1px solid rgba(217,119,6,.07)}
.prov-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.prov-head .led{width:7px;height:7px;border-radius:50%;background:var(--dim)}
.prov-head .led.g{background:var(--g2);box-shadow:0 0 8px var(--g)}
.prov-head .led.c{background:var(--c2);box-shadow:0 0 8px var(--c)}
.prov-title{font-family:var(--font-ui);font-size:10px;letter-spacing:.2em;color:var(--tx2);flex:1}
.prov-title.active{color:var(--p2)}
.key-badge{font-family:var(--font-ui);font-size:8px;padding:2px 8px;border-radius:3px}
.key-badge.ok{background:rgba(16,185,129,.15);color:var(--g2)}
.key-badge.no{background:rgba(239,68,68,.1);color:var(--r)}
.model-chips{display:flex;flex-wrap:wrap;gap:6px;max-height:130px;overflow-y:auto;margin-bottom:10px}
.model-chip{
  padding:4px 12px;border-radius:3px;cursor:pointer;font-size:11px;
  border:1px solid rgba(29,78,216,.12);background:rgba(29,78,216,.03);color:var(--tx2);
  transition:all .2s;
}
.model-chip:hover{border-color:var(--p);color:var(--p2);background:rgba(29,78,216,.1)}
.model-chip.sel{border-color:var(--g);color:var(--g2);background:rgba(16,185,129,.1)}
.pk-key-row{display:flex;gap:8px;margin-top:6px}
.pk-key-inp{
  flex:1;background:rgba(29,78,216,.04);border:1px solid rgba(29,78,216,.12);
  border-radius:4px;padding:6px 12px;color:var(--tx);font-size:11px;font-family:var(--font-mono);outline:none;
}
.pk-key-inp:focus{border-color:var(--p)}
.pk-key-save{
  padding:6px 14px;border-radius:4px;border:none;cursor:pointer;
  background:rgba(29,78,216,.18);color:var(--p3);font-family:var(--font-ui);font-size:9px;letter-spacing:.1em;
}

/* ═══════ SYSTEM MAP MODAL ═══════ */
#systemMapModal{
  position:fixed;inset:0;z-index:910;background:rgba(2,4,10,.9);
  display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(8px);
}
#systemMapModal.open{display:flex}
.system-map-box{
  width:min(980px,94vw);max-height:86vh;overflow:auto;
  background:rgba(5,9,17,.96);border:1px solid rgba(45,212,191,.25);
  border-radius:6px;padding:18px;
  box-shadow:0 0 60px rgba(45,212,191,.16),0 36px 80px rgba(0,0,0,.72);
}
.system-map-header{
  display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;
  font-family:var(--font-ui);font-size:11px;letter-spacing:.24em;color:#67e8f9;
}
.sys-map-grid{display:grid;grid-template-columns:2fr 1.2fr;gap:12px}
.sys-map-panel{
  border:1px dashed rgba(255,255,255,.14);border-radius:4px;padding:10px;background:rgba(0,0,0,.28);
}
.sys-map-visual{
  margin:8px 0 12px;
  border:1px solid rgba(45,212,191,.2);
  border-radius:4px;
  background:linear-gradient(180deg,rgba(12,18,32,.82),rgba(8,12,24,.84));
  padding:6px;
}
.sys-map-svg{width:100%;height:180px;display:block}
.sys-map-link{fill:none;stroke-width:2.2;stroke-linecap:round;stroke-dasharray:10 10;animation:flowDash 2.4s linear infinite}
.sys-map-link.edge{stroke:rgba(167,139,250,.9)}
.sys-map-link.auth{stroke:rgba(248,113,113,.88)}
.sys-map-link.api{stroke:rgba(251,146,60,.9)}
.sys-map-link.llm{stroke:rgba(45,212,191,.92)}
.sys-map-link.data{stroke:rgba(163,230,53,.88)}
.sys-map-node{fill:rgba(191,219,254,.95);filter:drop-shadow(0 0 6px rgba(147,197,253,.65));animation:nodePulse 1.8s ease-in-out infinite}
.sys-map-node.n2{animation-delay:.28s}
.sys-map-node.n3{animation-delay:.56s}
.sys-map-node.n4{animation-delay:.84s}
.sys-map-node.n5{animation-delay:1.12s}
.sys-map-label{font-family:var(--font-ui);font-size:9px;letter-spacing:.1em;fill:#b5d4ff}
.sys-map-badge-pulse{animation:badgePulse 2.4s ease-in-out infinite}
.sys-map-close{
  width:34px;height:34px;border-radius:4px;border:1px solid rgba(255,255,255,.18);
  background:rgba(255,255,255,.04);color:var(--tx2);cursor:pointer;font-size:16px;
}
.sys-map-close:hover{color:var(--r);border-color:var(--r);background:rgba(239,68,68,.14)}
@media (max-width: 980px){
  #systemMapBadge{right:16px;top:58px}
  .sys-map-grid{grid-template-columns:1fr}
  .sys-map-svg{height:150px}
}
@keyframes flowDash{to{stroke-dashoffset:-42}}
@keyframes nodePulse{0%,100%{opacity:.55;r:4.5}50%{opacity:1;r:6}}
@keyframes badgePulse{0%,100%{box-shadow:0 16px 38px rgba(0,0,0,.38),0 0 0 rgba(45,212,191,0)}50%{box-shadow:0 16px 38px rgba(0,0,0,.38),0 0 22px rgba(45,212,191,.22)}}

/* ═══════ ELEVENLABS WIDGET ═══════ */
#elevenWidget{
  position:fixed;bottom:95px;right:18px;z-index:300;
  display:none;
}

/* ═══════ SCROLLBAR GLOBAL ═══════ */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--dim);border-radius:2px}

/* ═══════ CORNER LABELS ═══════ */
.corner-label-group{display:flex;flex-direction:column;align-items:center}

/* ═══════ TOAST ═══════ */
#toast{
  position:fixed;bottom:120px;left:50%;transform:translateX(-50%) translateY(20px);
  background:rgba(16,185,129,.12);border:1px solid rgba(16,185,129,.25);
  border-radius:4px;padding:8px 20px;font-size:12px;color:var(--g2);
  z-index:9000;pointer-events:none;opacity:0;
  transition:opacity .3s,transform .3s;
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ═══════ MEMORY PANEL inside console ═══════ */
.fact-chip{
  display:flex;align-items:flex-start;gap:8px;padding:7px 10px;border-radius:4px;
  background:rgba(29,78,216,.05);border:1px solid rgba(29,78,216,.1);margin-bottom:5px;
  font-size:11px;color:var(--tx2);line-height:1.5;
}
.fact-chip .rm{cursor:pointer;color:var(--dim);font-size:10px;flex-shrink:0;margin-left:auto}
.fact-chip .rm:hover{color:var(--r)}

/* ═══════ RIGHT PANEL TABS ═══════ */
.rpanel-tabs{display:flex;border-bottom:1px solid rgba(29,78,216,.15);flex-shrink:0}
.rpanel-tab{
  flex:1;padding:9px 4px;text-align:center;cursor:pointer;
  font-family:var(--font-ui);font-size:8px;letter-spacing:.12em;
  color:var(--tx2);transition:all .2s;border-bottom:2px solid transparent;user-select:none;
}
.rpanel-tab:hover{color:var(--c2);background:rgba(6,182,212,.05)}
.rpanel-tab.active{color:var(--c2);border-bottom-color:var(--c);background:rgba(6,182,212,.06)}
.rpanel-pane{flex:1;overflow:hidden;display:flex;flex-direction:column}

/* ═══════ SYSTEM CONCEPT MAP (inspired by architecture diagrams) ═══════ */
.sys-concept-wrap{
  margin-top:14px;
  padding:12px;
  border:1px dashed rgba(255,255,255,.12);
  border-radius:4px;
  background:rgba(255,255,255,.02);
}
.sys-concept-title{
  font-family:var(--font-ui);font-size:8px;letter-spacing:.22em;
  color:var(--tx2);margin-bottom:10px;
}
.sys-zones{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.sys-zone{
  border:1px dashed rgba(255,255,255,.16);
  border-radius:4px;
  background:rgba(0,0,0,.25);
  padding:8px;
}
.sys-zone-title{
  font-family:var(--font-ui);font-size:8px;letter-spacing:.14em;
  color:var(--tx2);margin-bottom:7px;
}
.sys-chip-row{display:flex;flex-wrap:wrap;gap:6px}
.sys-chip{
  border-radius:3px;
  padding:4px 7px;
  font-size:10px;
  font-family:var(--font-ui);
  letter-spacing:.08em;
  border:1px solid transparent;
  color:#fff;
}
.chip-frontend{background:rgba(107,70,193,.25);border-color:rgba(167,139,250,.45)}
.chip-auth{background:rgba(220,38,38,.25);border-color:rgba(248,113,113,.45)}
.chip-backend{background:rgba(234,88,12,.24);border-color:rgba(251,146,60,.5)}
.chip-llm{background:rgba(13,148,136,.24);border-color:rgba(45,212,191,.48)}
.chip-storage{background:rgba(101,163,13,.24);border-color:rgba(163,230,53,.48)}
.chip-stream{background:rgba(219,39,119,.22);border-color:rgba(244,114,182,.45)}
.sys-flow{
  margin-top:10px;
  display:grid;
  gap:5px;
}
.sys-flow-line{
  font-size:10px;
  color:var(--tx2);
  background:rgba(29,78,216,.05);
  border:1px solid rgba(29,78,216,.14);
  border-radius:3px;
  padding:5px 7px;
}
@media (max-width: 1200px){
  .sys-zones{grid-template-columns:1fr}
}

/* ═══════ EL AGENT ═══════ */
.el-status-dot{
  width:10px;height:10px;border-radius:50%;background:var(--dim);
  display:inline-block;margin-right:6px;transition:all .4s;flex-shrink:0;
}
.el-status-dot.active{background:var(--g2);box-shadow:0 0 10px var(--g);animation:elPulse 1.5s ease-in-out infinite}
.el-status-dot.starting{background:var(--gold);box-shadow:0 0 8px var(--gold);animation:elPulse .8s ease-in-out infinite}
.el-status-dot.error{background:var(--r);box-shadow:0 0 8px var(--r)}
@keyframes elPulse{0%,100%{opacity:1}50%{opacity:.4}}
.el-agent-bar{
  padding:12px;border-radius:4px;
  background:rgba(6,182,212,.04);border:1px solid rgba(6,182,212,.12);margin-bottom:10px;
}
.el-btn-row{display:flex;gap:8px;margin-top:10px}
.el-btn{
  flex:1;padding:9px 8px;border-radius:4px;border:1px solid rgba(6,182,212,.25);
  background:rgba(6,182,212,.08);color:var(--c2);font-family:var(--font-ui);
  font-size:9px;letter-spacing:.15em;cursor:pointer;transition:all .2s;
}
.el-btn:hover{background:rgba(6,182,212,.2);border-color:var(--c)}
.el-btn.stop{border-color:rgba(239,68,68,.25);background:rgba(239,68,68,.06);color:var(--r)}
.el-btn.stop:hover{background:rgba(239,68,68,.18)}
.el-btn.wide{flex:none;width:100%;margin-top:8px;font-size:8px;text-align:center}
.el-conv-log{
  height:140px;overflow-y:auto;background:rgba(0,0,0,.3);
  border:1px solid rgba(29,78,216,.1);border-radius:4px;
  padding:8px;font-size:10px;color:var(--tx2);line-height:1.7;
  scrollbar-width:thin;scrollbar-color:var(--dim) transparent;
}

/* ═══════ TRANSCRIPT BAR ═══════ */
#transcriptBar{
  position:fixed;bottom:88px;left:50%;transform:translateX(-50%);
  width:min(700px,88vw);z-index:99;
  background:rgba(6,182,212,.08);border:1px solid rgba(6,182,212,.2);
  border-radius:4px;padding:7px 16px;
  font-family:var(--font-mono);font-size:12px;color:var(--c2);
  display:none;align-items:center;gap:10px;backdrop-filter:blur(10px);
  animation:fadeInUp .2s ease;
}
@keyframes fadeInUp{from{opacity:0;transform:translateX(-50%) translateY(6px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* ═══════ BARGE-IN HINT ═══════ */
#bargeInHint{
  font-family:var(--font-ui);font-size:9px;letter-spacing:.2em;
  color:var(--c2);margin-top:4px;
  animation:bargeGlow 1.5s ease-in-out infinite;
  display:none;text-align:center;pointer-events:none;
}
@keyframes bargeGlow{0%,100%{opacity:.4}50%{opacity:1}}

/* ═══════ LATENCY BADGE ═══════ */
#latencyBadge{
  position:fixed;top:16px;left:20px;z-index:200;
  font-family:var(--font-ui);font-size:9px;letter-spacing:.15em;
  background:rgba(8,6,0,.88);backdrop-filter:blur(12px);
  border:1px solid rgba(245,158,11,.2);border-radius:4px;
  padding:6px 12px;color:var(--gold);display:none;
}

/* ═══════ CLIPBOARD PREVIEW ═══════ */
#clipboardPreview{
  width:100%;margin-top:6px;padding:7px 10px;
  background:rgba(0,0,0,.35);border:1px solid rgba(29,78,216,.1);
  border-radius:4px;font-family:var(--font-mono);font-size:10px;
  color:var(--tx2);resize:none;outline:none;min-height:44px;
  scrollbar-width:thin;
}
.provider-pill{
  display:inline-flex;align-items:center;gap:4px;
  padding:1px 6px;border-radius:10px;font-size:9px;font-weight:700;
  letter-spacing:.1em;transition:background .3s,color .3s;
  background:rgba(255,255,255,.06);color:var(--tx2);
}
.provider-pill::before{
  content:'';width:5px;height:5px;border-radius:50%;
  background:currentColor;flex-shrink:0;transition:background .3s;
}
.provider-pill.p-elevenlabs{background:rgba(124,58,237,.18);color:#a78bfa}
.provider-pill.p-groq{background:rgba(234,88,12,.18);color:#fb923c}
.provider-pill.p-local{background:rgba(75,85,99,.25);color:#9ca3af}
.provider-pill.p-auto{background:rgba(8,145,178,.15);color:#22d3ee}
.provider-pill.p-active{animation:pill-pulse 1s ease-in-out infinite}
@keyframes pill-pulse{0%,100%{opacity:1}50%{opacity:.55}}

/* Always-listening indicator on mic button */
#micBtn.always-on{
  position:relative;
}
#micBtn.always-on::after{
  content:'';position:absolute;top:-2px;right:-2px;
  width:7px;height:7px;border-radius:50%;
  background:#22c55e;border:1px solid #000;
  animation:live-dot 2s ease-in-out infinite;
}
@keyframes live-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(.8)}}
#micBtn.recording-glow{
  color:#22d3ee!important;
  filter:drop-shadow(0 0 6px #22d3ee);
}
</style>
