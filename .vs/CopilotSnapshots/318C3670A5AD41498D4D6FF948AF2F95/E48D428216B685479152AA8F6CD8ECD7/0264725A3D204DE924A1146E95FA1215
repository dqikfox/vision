document.getElementById('textInput').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendText(); }
});
function sendText() {
  const inp = document.getElementById('textInput');
  const t = inp.value.trim();
  if (!t) return;
  inp.value = '';
  addMessage('user', t);
  send({ type:'input', text:t });
}

/* ═══════════════════════════════════════
   MIC / MODE
═══════════════════════════════════════ */
function toggleMute() {
  if (!continuousEnabled && !wakeWordEnabled) {
    const btn = document.getElementById('micBtn');
    muted = false;
    send({ type:'set_mute', muted:false });
    send({ type:'start_voice_capture' });
    btn.textContent = '🎙';
    btn.style.color = 'var(--g2)';
    btn.classList.remove('always-on');
    setOrbState('listening');
    toast('🎙 Speak now', 'green');
    return;
  }
  muted = !muted;
  send({ type:'set_mute', muted });
  const btn = document.getElementById('micBtn');
  btn.textContent = muted ? '🚫' : '🎙';
  btn.style.color = muted ? 'var(--r)' : 'var(--tx2)';
  btn.classList.toggle('always-on', !muted && continuousEnabled);
  setOrbState(muted ? 'muted' : 'idle');
  toast(muted ? 'Mic muted' : (continuousEnabled ? 'Mic active — always listening' : 'Mic active — voice standby'));
}
function toggleWakeWord() {
  wakeWordEnabled = !wakeWordEnabled;
  send({ type:'set_wake_word', enabled: wakeWordEnabled });
  const btn = document.getElementById('wakeBtn');
  const lbl = document.getElementById('wakeLbl');
  btn.textContent = wakeWordEnabled ? '🔒' : '🔓';
  btn.style.color = wakeWordEnabled ? 'var(--gold)' : 'var(--tx2)';
  lbl.textContent = wakeWordEnabled ? 'WAKE ON' : 'WAKE';
  toast(wakeWordEnabled ? '🔒 Wake-word ON — say "hey vision"' : '🔓 Wake-word OFF');
}
const modes = ['chat','operator'];
const modeIcons = { chat:'💬', operator:'🖥' };
function updateModeUI() {
  document.getElementById('modeBtn').textContent = modeIcons[currentMode];
  document.getElementById('modeLbl').textContent = currentMode.toUpperCase();
  const isOp = currentMode === 'operator';
  document.getElementById('modeBtn').classList.toggle('mode-op', isOp);
}
function cycleMode() {
  const idx = (modes.indexOf(currentMode)+1) % modes.length;
  currentMode = modes[idx];
  send({ type:'set_mode', mode:currentMode });
  updateModeUI();
  toast(`Mode: ${currentMode.toUpperCase()}`);
}

