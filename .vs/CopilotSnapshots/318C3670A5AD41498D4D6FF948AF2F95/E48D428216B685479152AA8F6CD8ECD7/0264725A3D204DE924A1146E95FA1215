async function startElAgent() {
  updateElAgentStatus('starting', 'Connecting to ConvAI…');
  try {
    const r = await fetch(API_URL + '/api/el-agent/start', { method:'POST' });
    const d = await r.json();
    if (!r.ok || !d.ok) {
      const message = formatElAgentMessage(d.error || d.message || `Failed to start (${r.status})`);
      updateElAgentStatus('error', message);
      logElAgent(`✗ ${message}`);
      return;
    }
    updateElAgentStatus(d.status || 'starting', d.message || 'Connecting to ConvAI…');
    logElAgent('▶ Agent start requested');
  } catch(e) { updateElAgentStatus('error', formatElAgentMessage(e.message)); }
}

async function stopElAgent() {
  try {
    await fetch(API_URL + '/api/el-agent/stop', { method:'POST' });
    updateElAgentStatus('inactive', 'Agent stopped');
    logElAgent('■ Agent stopped');
  } catch(e) { updateElAgentStatus('error', e.message); }
}

function formatElAgentMessage(message) {
  const text = String(message || '').trim();
  const lower = text.toLowerCase();
  if (lower.includes('invalid api key') || lower.includes('invalid_api_key')) {
    return 'ElevenLabs agent start failed: the saved ElevenLabs API key is invalid. The browser widget can still load, but backend ConvAI activation will stay unavailable until the key is replaced.';
  }
  return text;
}

function updateElAgentStatus(status, message) {
  elAgentStatus = status;
  const dot = document.getElementById('elAgentDot');
  const lbl = document.getElementById('elAgentStatus');
  const msg = document.getElementById('elAgentMsg');
  const colors = { inactive:'var(--dim)', starting:'var(--gold)', active:'var(--g2)', idle:'var(--p2)', error:'var(--r)' };
  if (dot) { dot.className = 'el-status-dot ' + status; dot.style.background = colors[status] || 'var(--dim)'; }
  if (lbl) lbl.textContent = status.toUpperCase();
  if (msg && message) msg.textContent = formatElAgentMessage(message);
}

function logElAgent(text) {
  const log = document.getElementById('elConvLog');
  if (!log) return;
  const ts = new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  log.innerHTML += `<div style="color:var(--c3)">[${ts}] ${escHtml(text)}</div>`;
  log.scrollTop = log.scrollHeight;
}

/* ═══════════════════════════════════════
   RIGHT PANEL TABS
═══════════════════════════════════════ */
function switchRTab(tab) {
  document.querySelectorAll('.rpanel-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.rpanel-pane').forEach(p => p.style.display = 'none');
  const activeTab = document.querySelector(`.rpanel-tab[data-tab="${tab}"]`);
  const activePane = document.getElementById('rpane-' + tab);
  if (activeTab) activeTab.classList.add('active');
  if (activePane) activePane.style.display = 'flex';
}

function openRPanelTab(tab) {
  switchRTab(tab);
  document.getElementById('panelRight').classList.add('pinned');
  if (tab === 'agent') showElevenWidgetInPanel();
  setTimeout(() => document.getElementById('panelRight').classList.remove('pinned'), 4000);
}

/* ═══════════════════════════════════════
   TRANSCRIPT BAR
═══════════════════════════════════════ */
function showTranscriptBar(text) {
  const bar = document.getElementById('transcriptBar');
  const span = document.getElementById('transcriptText');
  const lbl = document.getElementById('transcriptLabel');
  if (!bar || !span) return;
  if (lbl) {
    if (text === '🎙 Listening…') lbl.textContent = 'LISTENING';
    else if (text.startsWith('🎙 ') && text.length > 10) lbl.textContent = 'HEARD';
    else lbl.textContent = 'HEARING';
  }
  span.textContent = text;
  bar.style.display = 'flex';
  clearTimeout(window._transcriptTimer);
  if (text.startsWith('🎙 ') && text.length > 10) {
    window._transcriptTimer = setTimeout(hideTranscriptBar, 3500);
  } else if (!text) {
    hideTranscriptBar();
  }
}
function hideTranscriptBar() {
  const bar = document.getElementById('transcriptBar');
  if (bar) bar.style.display = 'none';
}

/* ═══════════════════════════════════════
   LATENCY
═══════════════════════════════════════ */
function showLatency(ms) {
  const badge = document.getElementById('latencyBadge');
  if (!badge) return;
  badge.textContent = `⚡ ${ms < 1000 ? ms + 'ms' : (ms/1000).toFixed(1) + 's'} latency`;
  badge.style.display = 'block';
  setTimeout(() => { badge.style.display = 'none'; }, 5000);
}

/* ═══════════════════════════════════════
   VOICE LOADER
═══════════════════════════════════════ */
async function loadVoices() {
  try {
    const r = await fetch(API_URL + '/api/voices');
    const d = await r.json();
    const localVoices = (d.providers?.local?.voices || d.voices || []).map((voice) => ({
      ...voice,
      name: String(voice.name || '').replace('Microsoft ', '').replace(' Desktop', ''),
    }));
    const elevenVoices = d.providers?.elevenlabs?.voices || [];
    voiceCatalog = {
      local: {
        label: d.providers?.local?.label || 'Windows Local Voices',
        available: (d.providers?.local?.available ?? localVoices.length > 0),
        voices: localVoices,
      },
      elevenlabs: {
        label: d.providers?.elevenlabs?.label || 'ElevenLabs',
        available: !!d.providers?.elevenlabs?.available,
        voices: elevenVoices,
      },
    };
    renderVoiceOptions(voiceSettings.preferred_tts || 'auto');
    updateHeroDeck();
  } catch(e) {
    voiceCatalog = {
      local: { label:'Windows Local Voices', available:false, voices:[] },
      elevenlabs: { label:'ElevenLabs', available:false, voices:[] },
    };
    updateVoiceProviderSummary(voiceSettings.preferred_tts || 'auto');
    const hint = document.getElementById('voiceLoadHint');
    if (hint) hint.textContent = 'Voices unavailable';
  }
}

/* ═══════════════════════════════════════
   NEW QUICK ACTIONS
