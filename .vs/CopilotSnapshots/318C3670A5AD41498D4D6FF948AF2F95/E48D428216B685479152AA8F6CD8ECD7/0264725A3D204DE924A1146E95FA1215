function selectRadio(el, groupId) {
  // Remove 'on' class from all radio buttons in the group
  document.getElementById(groupId).querySelectorAll('.r-opt').forEach(r => {
    r.classList.remove('on','on-c');
    // Update ARIA attributes
    if (r.role === 'radio') {
      r.setAttribute('aria-checked', 'false');
    }
  });
  // Add 'on' class to selected radio button
  el.classList.add('on');
  // Update ARIA attributes for selected radio button
  if (el.role === 'radio') {
    el.setAttribute('aria-checked', 'true');
  }
  if (groupId === 'ttsRadios') renderVoiceOptions(el.dataset.val || 'auto');
  if (groupId === 'voiceRadios') updateHeroDeck();
}

function togglePanel(panelId) {
  const panel = document.getElementById(panelId);
  if (panel) {
    panel.classList.toggle('pinned');
    // Clear any inline transform that might conflict
    if (!panel.classList.contains('pinned')) {
      panel.style.transform = '';
    }
  }
}

function applyVoiceSettings(v) {
  voiceSettings = { ...voiceSettings, ...v };
  const applyGroup = (id, val) => {
    const g = document.getElementById(id); if (!g) return;
    g.querySelectorAll('.r-opt').forEach(r => r.classList.toggle('on', r.dataset.val === String(val)));
  };
  applyGroup('sttRadios', v.preferred_stt || v.stt || 'auto');
  applyGroup('ttsRadios', v.preferred_tts || v.tts || 'auto');
  const rate = v.tts_rate || 175;
  const sl = document.getElementById('ttsRate');
  if (sl) { sl.value = rate; document.getElementById('ttsRateVal').textContent = rate; }
  updateProviderPill('hudSTT', v.preferred_stt || 'auto', false);
  updateProviderPill('hudTTS', v.preferred_tts || 'auto', false);
  renderVoiceOptions(v.preferred_tts || v.tts || 'auto');
  updateHeroDeck();
}
function saveVoiceSettings() {
  const stt = document.querySelector('#sttRadios .r-opt.on')?.dataset.val || 'auto';
  const tts = document.querySelector('#ttsRadios .r-opt.on')?.dataset.val || 'auto';
  const selectedVoice = document.querySelector('#voiceRadios .r-opt.on');
  const voiceProvider = selectedVoice?.dataset.provider || resolveVoiceProvider(tts);
  const voice = parseInt(selectedVoice?.dataset.index || `${voiceSettings.tts_voice_idx ?? 0}`, 10);
  const voiceId = selectedVoice?.dataset.voiceId || voiceSettings.tts_voice_id || '';
  const rate  = parseInt(document.getElementById('ttsRate')?.value || '175');
  send({
    type:'set_voice_settings',
    preferred_stt:stt,
    preferred_tts:tts,
    tts_rate:rate,
    tts_voice_idx:Number.isFinite(voice) ? voice : 0,
    tts_voice_id:voiceProvider === 'elevenlabs' ? voiceId : (voiceSettings.tts_voice_id || ''),
  });
  toast('Voice settings applied!', 'green');
}

