    atmo.addColorStop(1, 'transparent');
    ctx.fillStyle = atmo; ctx.fillRect(0,0,W,H);

    // Mid glow ring
    const midGlow = ctx.createRadialGradient(cx, cy, 50, cx, cy, 100);
    midGlow.addColorStop(0, col.glow + ((.1 + .08*pulse).toFixed(2)) + ')');
    midGlow.addColorStop(1, 'transparent');
    ctx.fillStyle = midGlow; ctx.beginPath(); ctx.arc(cx,cy,100,0,6.28); ctx.fill();

    // Wavy orb blob
    ctx.beginPath();
    const baseR = 62 + volBoost;
    for (let a = 0; a <= 6.30; a += 0.04) {
      const w1 = amp * 5 * Math.sin(a * 3 + t * speed);
      const w2 = amp * 3 * Math.sin(a * 5 - t * speed * .7);
      const w3 = amp * 2 * Math.sin(a * 7 + t * speed * .4);
      const r = baseR + w1 + w2 + w3;
      const x = cx + r * Math.cos(a);
      const y = cy + r * Math.sin(a);
      a < 0.05 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.closePath();
    const grad = ctx.createRadialGradient(cx, cy-20, 0, cx, cy, baseR + 20);
    grad.addColorStop(0,  col.c2 + 'ff');
    grad.addColorStop(.4, col.c1 + 'dd');
    grad.addColorStop(.8, col.c3 + 'aa');
    grad.addColorStop(1,  col.c1 + '44');
    ctx.fillStyle = grad;
    ctx.shadowColor = col.c1;
    ctx.shadowBlur = 30 + 20*pulse;
    ctx.fill();
    ctx.shadowBlur = 0;

    // Inner highlight (specular)
    ctx.beginPath();
    ctx.ellipse(cx-18, cy-20, 22, 14, -.6, 0, 6.28);
    ctx.fillStyle = 'rgba(255,255,255,0.18)';
    ctx.fill();

    // Secondary highlight
    ctx.beginPath();
    ctx.ellipse(cx+14, cy+18, 8, 5, .4, 0, 6.28);
    ctx.fillStyle = 'rgba(255,255,255,0.08)';
    ctx.fill();

    // Pulse ring
    const pr = 78 + 22*pulse + volBoost*.6;
    ctx.beginPath(); ctx.arc(cx,cy,pr,0,6.28);
    ctx.strokeStyle = col.c1 + (orbState === 'idle' ? '20' : '35');
    ctx.lineWidth = 1.5; ctx.stroke();

    // Second slower pulse ring
    const pr2 = 95 + 15 * Math.sin(t * .4);
    ctx.beginPath(); ctx.arc(cx,cy,pr2,0,6.28);
    ctx.strokeStyle = col.c2 + '12';
    ctx.lineWidth = 1; ctx.stroke();

    // Core bright center
    const core = ctx.createRadialGradient(cx,cy,0,cx,cy,20);
    core.addColorStop(0, 'rgba(255,255,255,0.55)');
    core.addColorStop(.5, col.c2 + '80');
    core.addColorStop(1, 'transparent');
    ctx.fillStyle = core; ctx.beginPath(); ctx.arc(cx,cy,20,0,6.28); ctx.fill();

    requestAnimationFrame(draw);
  }
  draw();
  window.setOrbState = (s) => {
    orbState = s;
    const canvas2 = document.getElementById('orbCanvas');
    canvas2.className = s;
  };
  window.setOrbVolume = (v) => { volume = Math.min(v, 1); };
})();

