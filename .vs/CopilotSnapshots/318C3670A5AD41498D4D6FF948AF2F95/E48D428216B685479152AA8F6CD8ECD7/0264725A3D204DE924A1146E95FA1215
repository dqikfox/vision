  send({ type:'execute_tool', tool:'set_clipboard', args:{ text:'' } });
  const preview = document.getElementById('clipboardPreview');
  if (preview) preview.value = '';
  toast('Clipboard cleared');
}

function launchVSCode() {
  send({ type:'execute_tool', tool:'run_command', args:{ command:'code .' } });
  toast('Launching VS Code…');
}

function aiCmd(text) {
