<script>
/* ═══════════════════════════════════════
   3D AVATAR RENDERER
═══════════════════════════════════════ */
let avatarScene, avatarCamera, avatarRenderer, avatarModel, avatarMixer;
let avatarAnimationId = null;

function init3DAvatar() {
  // Wait for Three.js to load
  if (typeof THREE === 'undefined' || typeof window.GLTFLoader === 'undefined' || !window.THREE_LOADED) {
    console.log('Waiting for Three.js modules to load...');
    setTimeout(init3DAvatar, 100);
    return;
  }

  console.log('Initializing 3D Avatar...');

  const canvas = document.getElementById('heroAvatar');
  const container = document.getElementById('heroAvatarFrame');
  if (!canvas || !container) return;

  const width = container.clientWidth;
  const height = container.clientHeight;

  canvas.width = width;
  canvas.height = height;

  // Scene
  avatarScene = new THREE.Scene();
  avatarScene.background = null;

  // Camera
  avatarCamera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
  avatarCamera.position.set(0, 1.2, 3.5);
  avatarCamera.lookAt(0, 1, 0);

  // Renderer
  avatarRenderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
  avatarRenderer.setSize(width, height);
  avatarRenderer.setPixelRatio(window.devicePixelRatio);
  avatarRenderer.shadowMap.enabled = true;
  avatarRenderer.shadowMap.type = THREE.PCFSoftShadowMap;
  avatarRenderer.toneMapping = THREE.ACESFilmicToneMapping;
  avatarRenderer.toneMappingExposure = 1.2;

  // Lighting - Ultron-themed
  const ambientLight = new THREE.AmbientLight(0x4f46e5, 0.4);
  avatarScene.add(ambientLight);

  const keyLight = new THREE.DirectionalLight(0x06b6d4, 1.2);
  keyLight.position.set(2, 3, 2);
  keyLight.castShadow = true;
  avatarScene.add(keyLight);

  const fillLight = new THREE.DirectionalLight(0x4f46e5, 0.6);
  fillLight.position.set(-2, 1, -1);
  avatarScene.add(fillLight);

  const rimLight = new THREE.PointLight(0x22c55e, 0.8, 10);
  rimLight.position.set(0, 2, -2);
  avatarScene.add(rimLight);

  // Load model
  console.log('Creating GLTFLoader...');
  const loader = new window.GLTFLoader();
  console.log('Loading model from /assets/ultron-avatar.glb...');
  loader.load(
    '/assets/ultron-avatar.glb',
    function (gltf) {
      console.log('Model load success callback triggered');
      avatarModel = gltf.scene;

      // Calculate bounds
      const box = new THREE.Box3().setFromObject(avatarModel);
      const center = box.getCenter(new THREE.Vector3());
      const size = box.getSize(new THREE.Vector3());

      console.log('Model bounds:', { center, size });

      // Scale to 3 units tall
      const targetHeight = 3;
      const scale = targetHeight / size.y;
      avatarModel.scale.setScalar(scale);

      // Center at origin
      const scaledCenter = center.clone().multiplyScalar(scale);
      avatarModel.position.set(-scaledCenter.x, -scaledCenter.y, -scaledCenter.z);

      avatarScene.add(avatarModel);

      // Position camera to see full model
      avatarCamera.position.set(0, 0, 6);
      avatarCamera.lookAt(0, 0, 0);

      // Apply materials with Ultron colors
      avatarModel.traverse(function (child) {
        if (child.isMesh) {
          child.castShadow = true;
          child.receiveShadow = true;
          if (child.material) {
            child.material.metalness = 0.7;
            child.material.roughness = 0.3;
            child.material.emissive = new THREE.Color(0x4f46e5);
            child.material.emissiveIntensity = 0.2;
          }
        }
      });

      // Setup animations if available
      if (gltf.animations && gltf.animations.length > 0) {
        avatarMixer = new THREE.AnimationMixer(avatarModel);
        const idleAction = avatarMixer.clipAction(gltf.animations[0]);
        idleAction.play();
      }

      console.log('3D Ultron avatar loaded successfully');
    },
    function (xhr) {
      console.log((xhr.loaded / xhr.total * 100) + '% loaded');
    },
    function (error) {
      console.error('Error loading 3D avatar:', error);
      // Fallback: create stylized geometry
      createFallbackAvatar();
    }
  );

  // Handle resize
  const resizeObserver = new ResizeObserver(() => {
    const newWidth = container.clientWidth;
    const newHeight = container.clientHeight;
    avatarCamera.aspect = newWidth / newHeight;
    avatarCamera.updateProjectionMatrix();
    avatarRenderer.setSize(newWidth, newHeight);
    canvas.width = newWidth;
    canvas.height = newHeight;
  });
  resizeObserver.observe(container);

  // Start animation loop
  animate3DAvatar();
}

function createFallbackAvatar() {
  // Stylized Ultron-like robot head
  const group = new THREE.Group();

  // Head
  const headGeo = new THREE.SphereGeometry(0.5, 32, 32);
  const headMat = new THREE.MeshStandardMaterial({
    color: 0x1e3a8a,
    metalness: 0.9,
    roughness: 0.2,
    emissive: 0x4f46e5,
    emissiveIntensity: 0.3
  });
  const head = new THREE.Mesh(headGeo, headMat);
  head.position.y = 1;
  head.castShadow = true;
  group.add(head);

  // Eyes (glowing)
  const eyeGeo = new THREE.SphereGeometry(0.08, 16, 16);
  const eyeMat = new THREE.MeshStandardMaterial({
    color: 0x06b6d4,
    emissive: 0x06b6d4,
    emissiveIntensity: 2
  });

  const leftEye = new THREE.Mesh(eyeGeo, eyeMat);
  leftEye.position.set(-0.15, 1.1, 0.4);
  group.add(leftEye);

  const rightEye = new THREE.Mesh(eyeGeo, eyeMat);
  rightEye.position.set(0.15, 1.1, 0.4);
  group.add(rightEye);

  // Jaw accent
  const jawGeo = new THREE.BoxGeometry(0.4, 0.15, 0.4);
  const jawMat = new THREE.MeshStandardMaterial({
    color: 0x0c1528,
    metalness: 0.8,
    roughness: 0.3
  });
  const jaw = new THREE.Mesh(jawGeo, jawMat);
  jaw.position.set(0, 0.7, 0.35);
  jaw.castShadow = true;
  group.add(jaw);

  avatarModel = group;
  avatarScene.add(group);
  console.log('Fallback 3D avatar created');
}

const clock = new THREE.Clock();
function animate3DAvatar() {
  avatarAnimationId = requestAnimationFrame(animate3DAvatar);

  const delta = clock.getDelta();

  // Update mixer for animations
  if (avatarMixer) {
    avatarMixer.update(delta);
  }

  // Idle rotation
  if (avatarModel && state === 'idle') {
    avatarModel.rotation.y += 0.003;
  }

  // State-based animations
  if (avatarModel) {
    const time = Date.now() * 0.001;

    switch (state) {
      case 'listening':
      case 'recording':
        avatarModel.position.y = Math.sin(time * 2) * 0.05;
        avatarModel.rotation.x = Math.sin(time * 1.5) * 0.02;
        break;
      case 'thinking':
        avatarModel.rotation.y += 0.01;
        avatarModel.position.y = Math.sin(time * 3) * 0.03;
        break;
      case 'speaking':
        avatarModel.position.y = Math.sin(time * 4) * 0.08;
        avatarModel.rotation.z = Math.sin(time * 2) * 0.01;
        break;
      default:
        // Return to neutral
        avatarModel.position.y *= 0.95;
        avatarModel.rotation.x *= 0.95;
        avatarModel.rotation.z *= 0.95;
    }
  }

  avatarRenderer.render(avatarScene, avatarCamera);
}
</script>

