function setMetricBar(id, barId, val) {
  const el = document.getElementById(id);
  const bar = document.getElementById(barId);
  if (!el || !bar || val === null || val === undefined) return;
  el.textContent = Math.round(val);
  bar.style.width = val + '%';
  bar.className = 'metric-bar-fill' + (val > 90 ? ' crit' : val > 70 ? ' warn' : '');
}

async function fetchMetrics() {
  try {
    const r = await fetch(API_URL + '/api/metrics');
    const d = await r.json();
    setMetricBar('cpuVal', 'cpuBar', d.cpu);
    setMetricBar('ramVal', 'ramBar', d.ram);
    setMetricBar('diskVal', 'diskBar', d.disk);
    if (d.gpu !== null && d.gpu !== undefined) {
      setMetricBar('gpuVal', 'gpuBar', d.gpu);
      setMetricBar('vramVal', 'vramBar', d.gpu_mem);
    }
  } catch(e) {}
}

async function fetchHealth() {
  try {
    const r = await fetch(API_URL + '/api/health');
    const d = await r.json();
    const setLed = (id, ok) => {
      const el = document.getElementById('led-' + id);
      if (el) { el.className = 'comp-led ' + (ok ? 'ok' : 'off'); }
    };
    setLed('ollama', d.ollama);
    setLed('elevenlabs', d.elevenlabs);
    setLed('browser', d.browser);
    setLed('gpu', d.gpu);
    setLed('ocr', d.ocr);
  } catch(e) {}
}

let _pollingStarted = false;
