    muted:     { c1:'#374151', c2:'#6b7280', c3:'#111827', glow:'rgba(55,65,81,' },
  };

  function draw() {
    ctx.clearRect(0,0,W,H);
    t += 0.018;
    const col = colors[orbState] || colors.idle;
    const amp = orbState === 'idle' ? 1 : orbState === 'thinking' ? 2 : 2.5;
