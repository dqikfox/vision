let continuousEnabled = false;
let modelCatalog = {};
const MODEL_PROVIDER_ORDER = ['ollama','openai','github','anthropic','deepseek','groq','mistral','gemini','xai','nvidia'];

function updateActiveCoreDisplay() {
  const el = document.getElementById('activeCore');
  if (el) el.textContent = `${currentProvider.toUpperCase()} / ${currentModel.toUpperCase()}`;
}

function toggleContinuous() {
  continuousEnabled = !continuousEnabled;
  send({ type: 'set_continuous', enabled: continuousEnabled });
  updateContinuousUI(continuousEnabled);
  const micBtn = document.getElementById('micBtn');
  if (micBtn) micBtn.classList.toggle('always-on', continuousEnabled && !muted);
  toast(continuousEnabled ? 'Always Listening ON' : 'Always Listening OFF', continuousEnabled ? 'green' : 'cyan');
}

function updateContinuousUI(enabled) {
  continuousEnabled = enabled;
  const btn = document.getElementById('btnContinuous');
  const lbl = document.getElementById('continuousLbl');
  if (btn) {
    btn.classList.toggle('active', enabled);
    btn.textContent = enabled ? '🟢' : '⚪';
    btn.style.color = enabled ? 'var(--g2)' : 'var(--tx2)';
    btn.style.borderColor = enabled ? 'var(--g)' : 'rgba(29,78,216,.2)';
  }
  if (lbl) lbl.textContent = enabled ? 'ALWAYS ON' : 'ALWAYS OFF';
}

function providerLabel(provider) {
  if (!provider) return 'No provider selected';
  if (provider === 'ollama') return 'Ollama (Local)';
  return modelCatalog[provider]?.label || provider.toUpperCase();
}

function providerIsSelectable(provider, meta = {}) {
  const models = meta.models || [];
  if (!models.length) return false;
  if (provider === currentProvider) return true;
  return provider === 'ollama' ? true : !!meta.has_key;
}

function orderedProviderKeys(providers) {
  const seen = new Set();
  const ordered = [];
  MODEL_PROVIDER_ORDER.forEach((key) => {
    if (providers[key]) {
      ordered.push(key);
      seen.add(key);
    }
  });
  Object.keys(providers).forEach((key) => {
    if (!seen.has(key) && key !== 'elevenlabs') ordered.push(key);
  });
  return ordered;
}

function updateRunningModelStatus() {
  const providerEl = document.getElementById('runningProviderValue');
  const modelEl = document.getElementById('runningModelValue');
  const noteEl = document.getElementById('modelSelectorNote');
  const providerMeta = modelCatalog[currentProvider] || {};
  const modelCount = (providerMeta.models || []).length;
  if (providerEl) {
    providerEl.textContent = providerLabel(currentProvider);
    providerEl.title = currentProvider || '';
  }
  if (modelEl) {
    modelEl.textContent = currentModel || 'No model selected';
    modelEl.title = currentModel || '';
  }
  if (noteEl) {
    noteEl.textContent = currentProvider && currentModel
      ? `Running now: ${providerLabel(currentProvider)} / ${currentModel}${modelCount ? ` • ${modelCount} models available for this provider` : ''}`
      : 'No active model is currently selected.';
  }
  updateHeroDeck();
}

function populateModelSelect(provider, preferredModel = currentModel) {
  const modelSelect = document.getElementById('modelSelect');
  if (!modelSelect) return '';
  const meta = modelCatalog[provider] || {};
  const models = meta.models || [];
  if (!models.length) {
    modelSelect.innerHTML = '<option value="">No models available</option>';
    modelSelect.disabled = true;
    return '';
  }
  modelSelect.disabled = false;
  modelSelect.innerHTML = models.map((model) => `<option value="${escAttr(model)}">${escHtml(model)}</option>`).join('');
  const selectedModel = models.includes(preferredModel) ? preferredModel : models[0];
  modelSelect.value = selectedModel;
  return selectedModel;
}

function syncModelSelectorsToCurrent() {
  const providerSelect = document.getElementById('providerSelect');
  if (!providerSelect) {
    updateRunningModelStatus();
    return;
  }
  const providerKeys = Object.keys(modelCatalog);
  if (!providerKeys.length) {
    updateRunningModelStatus();
    return;
  }
  const targetProvider = modelCatalog[currentProvider] ? currentProvider : providerSelect.value;
  if (targetProvider) {
    providerSelect.value = targetProvider;
    populateModelSelect(targetProvider, currentProvider === targetProvider ? currentModel : undefined);
  }
  updateRunningModelStatus();
}

function renderProviderSelect() {
  const providerSelect = document.getElementById('providerSelect');
  if (!providerSelect) return;
  const providerKeys = orderedProviderKeys(modelCatalog);
  if (!providerKeys.length) {
    providerSelect.innerHTML = '<option value="">No providers available</option>';
    providerSelect.disabled = true;
    populateModelSelect('', '');
    updateRunningModelStatus();
    return;
  }
  providerSelect.disabled = false;
  providerSelect.innerHTML = providerKeys.map((provider) => {
    const meta = modelCatalog[provider] || {};
    const hasModels = (meta.models || []).length > 0;
    const selectable = providerIsSelectable(provider, meta);
    let suffix = '';
    if (!hasModels) suffix = ' - NO MODELS';
    else if (provider !== 'ollama' && !meta.has_key) suffix = ' - NO KEY';
    else if (provider === currentProvider) suffix = ' - ACTIVE';
    return `<option value="${escAttr(provider)}" ${selectable ? '' : 'disabled'}>${escHtml(`${providerLabel(provider)}${suffix}`)}</option>`;
  }).join('');
  const fallbackProvider =
    (modelCatalog[currentProvider] && currentProvider) ||
    providerKeys.find((provider) => providerIsSelectable(provider, modelCatalog[provider])) ||
    providerKeys[0];
  providerSelect.value = fallbackProvider;
  populateModelSelect(fallbackProvider, currentProvider === fallbackProvider ? currentModel : undefined);
  updateRunningModelStatus();
}

async function refreshModelSelectors() {
  const providerSelect = document.getElementById('providerSelect');
  const modelSelect = document.getElementById('modelSelect');
  if (providerSelect) {
    providerSelect.innerHTML = '<option value="">Loading...</option>';
    providerSelect.disabled = true;
  }
  if (modelSelect) {
    modelSelect.innerHTML = '<option value="">Loading...</option>';
    modelSelect.disabled = true;
  }
  try {
    const response = await fetch(API_URL + '/api/models');
    const data = await response.json();
    currentProvider = data.current_provider || currentProvider;
    currentModel = data.current_model || currentModel;
    modelCatalog = data.providers || {};
    renderProviderSelect();
    syncModelSelectorsToCurrent();
  } catch (e) {
    if (providerSelect) providerSelect.innerHTML = '<option value="">Unavailable</option>';
    if (modelSelect) modelSelect.innerHTML = '<option value="">Unavailable</option>';
    const noteEl = document.getElementById('modelSelectorNote');
    if (noteEl) noteEl.textContent = `Unable to load model list: ${e.message}`;
  }
}

function applyModelSelection(provider, model, options = {}) {
  if (!provider || !model) return;
  send({ type:'set_model', provider, model });
  currentProvider = provider;
  currentModel = model;
  updateModelBadge();
  syncModelSelectorsToCurrent();
  if (options.closePicker) closePicker();
  toast(`Switched to ${provider}/${model}`, 'purple');
}

function handleProviderSelectChange() {
  const providerSelect = document.getElementById('providerSelect');
  if (!providerSelect) return;
  const provider = providerSelect.value;
  const model = populateModelSelect(provider);
  if (!model) {
    toast(`No usable models for ${providerLabel(provider)}`, 'red');
    return;
  }
  applyModelSelection(provider, model);
}

function handleModelSelectChange() {
  const providerSelect = document.getElementById('providerSelect');
  const modelSelect = document.getElementById('modelSelect');
  if (!providerSelect || !modelSelect || !modelSelect.value) return;
  applyModelSelection(providerSelect.value, modelSelect.value);
}

function updateModelBadge() {
  const b = document.getElementById('modelBadge');
  const heroDisplay = document.getElementById('heroModelDisplay');
  if (!b) return;
  if (currentModel) {
    // Truncate long model names for display
    const displayModel = currentModel.length > 25 ? currentModel.slice(0, 22) + '...' : currentModel;
    b.innerHTML = `<span style="color:var(--c2)">${currentProvider.toUpperCase()}</span> <span style="color:var(--tx2)">/</span> ${displayModel}`;
    b.classList.remove('no-model');
    b.title = `${currentProvider} / ${currentModel}`;
    if (heroDisplay) {
      heroDisplay.innerHTML = `<span style="color:var(--c2)">${currentProvider.toUpperCase()}</span> <span style="color:var(--tx2)">/</span> ${displayModel}`;
      heroDisplay.title = `${currentProvider} / ${currentModel}`;
    }
  } else {
    b.textContent = '⚠ SELECT MODEL';
    b.classList.add('no-model');
    b.title = 'Click to select a model';
    if (heroDisplay) {
      heroDisplay.textContent = '⬡ SELECT MODEL';
      heroDisplay.title = 'Click to select a model';
    }
  }
  updateRunningModelStatus();
}
async function openPicker() {
  document.getElementById('pickerModal').classList.add('open');
  document.getElementById('pickerBody').innerHTML = '<div style="padding:30px;text-align:center;color:var(--dim)">Loading…</div>';
  try {
    const r = await fetch(API_URL + '/api/models');
    renderPicker(await r.json());
  } catch(e) {
    document.getElementById('pickerBody').innerHTML = `<div style="padding:20px;color:var(--r)">Error: ${e.message}</div>`;
  }
}
function closePicker() { document.getElementById('pickerModal').classList.remove('open'); }
function openSystemMap() { document.getElementById('systemMapModal').classList.add('open'); }
function closeSystemMap() { document.getElementById('systemMapModal').classList.remove('open'); }
function escAttr(s) { return String(s).replace(/"/g,'&quot;'); }

function renderPicker(data) {
  const body = document.getElementById('pickerBody');
  const provs = data.providers || {};
  let html = '';

  // Ollama first
  if (provs.ollama) {
    const p = provs.ollama;
    const models = p.models || [];
    html += `<div class="prov-section">
      <div class="prov-head">
        <div class="led ${currentProvider==='ollama'?'g':'c'}"></div>
        <div class="prov-title ${currentProvider==='ollama'?'active':''}">🦙 OLLAMA — LOCAL</div>
        <span style="font-size:9px;color:var(--dim)">${models.length} models</span>
        ${currentProvider==='ollama'?'<span class="key-badge ok">ACTIVE</span>':''}
      </div>
      <div class="model-chips">
        ${models.map(m=>`<div class="model-chip ${currentProvider==='ollama'&&currentModel===m?'sel':''}" onclick="selectModel('ollama','${escAttr(m)}')">${escHtml(m)}</div>`).join('')||'<span style="color:var(--dim);font-size:11px">No models — run: ollama serve</span>'}
      </div>
    </div>`;
  }

  // Cloud providers
  orderedProviderKeys(provs).filter((key) => key !== 'ollama' && key !== 'elevenlabs').forEach(key => {
    const p = provs[key]; if (!p) return;
    const isActive = currentProvider === key;
    const hasKey = p.has_key;
    html += `<div class="prov-section">
      <div class="prov-head">
        <div class="led ${isActive?'g':hasKey?'c':''}"></div>
        <div class="prov-title ${isActive?'active':''}">${p.label||key}</div>
        ${isActive?'<span class="key-badge ok">ACTIVE</span>':''}
        <span class="key-badge ${hasKey?'ok':'no'}" style="margin-left:auto">${hasKey?'✓ KEY':'✗ NO KEY'}</span>
      </div>
      <div class="model-chips">
        ${(p.models||[]).map(m=>`<div class="model-chip ${isActive&&currentModel===m?'sel':''}" onclick="selectModel('${key}','${escAttr(m)}')">${escHtml(m)}</div>`).join('')||'<span style="color:var(--dim);font-size:11px">No models</span>'}
      </div>
      <div class="pk-key-row">
        <input class="pk-key-inp" id="pk_${key}" type="password" placeholder="${hasKey?'Key saved — paste to update':'Paste API key…'}"/>
        <button class="pk-key-save" onclick="saveKey('${key}')">SAVE</button>
      </div>
    </div>`;
  });

  // ElevenLabs
  const el11 = provs.elevenlabs || {};
  html += `<div class="prov-section">
    <div class="prov-head">
      <div class="led ${el11.has_key?'c':''}"></div>
      <div class="prov-title">🔊 ELEVENLABS — TTS / STT</div>
      <span class="key-badge ${el11.has_key?'ok':'no'}" style="margin-left:auto">${el11.has_key?'✓ KEY':'✗ NO KEY'}</span>
    </div>
    <div class="pk-key-row">
      <input class="pk-key-inp" id="pk_elevenlabs" type="password" placeholder="${el11.has_key?'Key saved — paste to update':'Paste ElevenLabs API key…'}"/>
      <button class="pk-key-save" onclick="saveKey('elevenlabs')">SAVE</button>
    </div>
  </div>`;

  body.innerHTML = html;
}

function selectModel(provider, model) {
  applyModelSelection(provider, model, { closePicker: true });
}
async function saveKey(provider) {
  const inp = document.getElementById('pk_' + provider);
  if (!inp) return;
  const key = inp.value.trim(); if (!key) return;
  send({ type:'set_api_key', provider, key });
  inp.value = ''; inp.placeholder = '✓ Key saved';
  toast(`Key saved: ${provider}`, 'green');
}

