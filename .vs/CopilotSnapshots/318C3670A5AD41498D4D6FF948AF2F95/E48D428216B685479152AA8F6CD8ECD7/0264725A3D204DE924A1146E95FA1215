  send({ type:'input', text });
  toast('AI command sent');
}

/* ═══════════════════════════════════════
   TOAST
═══════════════════════════════════════ */
let toastTimer;
function toast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.style.background = type==='green' ? 'rgba(16,185,129,.12)' :
                        type==='cyan'  ? 'rgba(6,182,212,.12)' :
                        type==='purple'? 'rgba(29,78,216,.12)' :
                        'rgba(29,78,216,.1)';
  el.style.borderColor = type==='green' ? 'rgba(16,185,129,.25)' :
                         type==='cyan'  ? 'rgba(6,182,212,.25)' :
                         type==='purple'? 'rgba(29,78,216,.25)' :
                         'rgba(29,78,216,.22)';
  el.style.color = type==='green' ? 'var(--g2)' :
                   type==='cyan'  ? 'var(--c2)' :
                   type==='purple'? 'var(--p2)' : 'var(--gold2)';
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);
}

/* ═══════════════════════════════════════
   ACCESSIBILITY FEATURES
═══════════════════════════════════════ */
function toggleHighContrast(enable) {
  if (enable) {
    document.documentElement.classList.add('high-contrast');
    toast('High contrast mode enabled', 'cyan');
  } else {
    document.documentElement.classList.remove('high-contrast');
    toast('Normal mode restored', 'green');
  }

  // Save the setting to the backend
  fetch('/api/accessibility/settings', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({ high_contrast: enable })
  }).catch(err => console.log('Failed to save accessibility settings:', err));
}

function toggleKeyboardNav(enable) {
  if (enable) {
    // Add keyboard navigation support
    document.body.setAttribute('data-keyboard-nav', 'true');
    // Add comprehensive focus styles
    let style = document.getElementById('keyboard-nav-styles');
    if (!style) {
      style = document.createElement('style');
      style.id = 'keyboard-nav-styles';
      style.textContent = `
        :focus {
          outline: 2px solid var(--p2) !important;
          outline-offset: 2px;
          z-index: 1000;
        }
        .r-opt:focus, .corner-btn:focus, .input-icon-btn:focus, .input-send-btn:focus,
        .panel-tab-left:focus, .panel-tab-right:focus, .panel-tab-top:focus,
        .msg-avatar:focus, .msg-bubble:focus, .key-inp:focus, .key-save:focus {
          outline: 2px solid var(--p2) !important;
          outline-offset: 2px;
          z-index: 1000;
        }
        /* Skip links for screen readers */
        .skip-link {
          position: absolute;
          top: -40px;
          left: 6px;
          background: var(--p);
          color: white;
          padding: 8px;
          text-decoration: none;
          border-radius: 0 0 4px 4px;
          z-index: 10000;
        }
        .skip-link:focus {
          top: 0;
        }
      `;
      document.head.appendChild(style);
    }
    toast('Keyboard navigation enabled', 'cyan');
  } else {
    document.body.removeAttribute('data-keyboard-nav');
    // Remove the styles when disabling
    const style = document.getElementById('keyboard-nav-styles');
    if (style) {
      style.remove();
    }
    toast('Keyboard navigation disabled', 'green');
  }

  // Save the setting to the backend
  fetch('/api/accessibility/settings', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({ keyboard_navigation: enable })
  }).catch(err => console.log('Failed to save accessibility settings:', err));
}

function saveAccessibilityVoiceSettings() {
  const pitch = parseInt(document.getElementById('ttsPitch')?.value || '50');
  const volume = parseInt(document.getElementById('ttsVolume')?.value || '100');
  const magnification = parseInt(document.getElementById('magnification')?.value || '100');

  // Save the settings to the backend
  fetch('/api/accessibility/settings', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      voice_pitch: pitch,
      voice_volume: volume,
      magnification: magnification / 100
    })
  })
  .then(response => {
    if (response.ok) {
      toast('Voice customization settings applied!', 'green');
      // Apply magnification to the page
      document.body.style.zoom = (magnification / 100);
    } else {
      toast('Failed to save voice settings', 'red');
    }
  })
  .catch(err => {
    console.log('Failed to save voice settings:', err);
    toast('Failed to save voice settings', 'red');
  });
}

// Load accessibility settings from backend
async function loadAccessibilitySettings() {
  try {
    const response = await fetch('/api/accessibility/settings');
    if (response.ok) {
      const settings = await response.json();

      // Apply high contrast mode
      if (settings.high_contrast) {
        document.documentElement.classList.add('high-contrast');
        // Update radio buttons to reflect current state
        document.querySelector('[onclick="toggleHighContrast(true)"]').classList.add('on');
        document.querySelector('[onclick="toggleHighContrast(false)"]').classList.remove('on');
      }

      // Apply keyboard navigation
      if (settings.keyboard_navigation) {
        document.body.setAttribute('data-keyboard-nav', 'true');
        // Update radio buttons to reflect current state
        document.querySelector('[onclick="toggleKeyboardNav(true)"]').classList.add('on');
        document.querySelector('[onclick="toggleKeyboardNav(false)"]').classList.remove('on');
      }

      // Apply voice settings if they exist
      if (settings.voice_rate) {
        const slider = document.getElementById('ttsRate');
        if (slider) {
          slider.value = settings.voice_rate;
          document.getElementById('ttsRateVal').textContent = settings.voice_rate;
        }
      }

      // Apply voice customization settings if they exist
      if (settings.voice_pitch !== undefined) {
        const pitchSlider = document.getElementById('ttsPitch');
        if (pitchSlider) {
          pitchSlider.value = settings.voice_pitch;
          document.getElementById('ttsPitchVal').textContent = settings.voice_pitch;
        }
      }

      if (settings.voice_volume !== undefined) {
        const volumeSlider = document.getElementById('ttsVolume');
        if (volumeSlider) {
          volumeSlider.value = settings.voice_volume;
          document.getElementById('ttsVolumeVal').textContent = settings.voice_volume;
        }
      }

      if (settings.magnification !== undefined) {
        const magSlider = document.getElementById('magnification');
        if (magSlider) {
          magSlider.value = Math.round(settings.magnification * 100);
          document.getElementById('magnificationVal').textContent = settings.magnification.toFixed(1);
        }
        // Apply magnification to the page
        document.body.style.zoom = settings.magnification;
      }
    }
  } catch (err) {
    console.log('Failed to load accessibility settings:', err);
  }
}
