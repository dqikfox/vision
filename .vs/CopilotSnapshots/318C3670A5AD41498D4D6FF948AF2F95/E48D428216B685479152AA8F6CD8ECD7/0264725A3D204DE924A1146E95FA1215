function connect() {
  ws = new WebSocket(WS_URL);
  ws.onopen = () => {
    wsRetry = 0; clearTimeout(wsTimer);
    document.getElementById('wsHudDot').classList.add('on');
    document.getElementById('wsHudLbl').textContent = 'ONLINE';
    toast('Connected to Vision Core', 'green');
    startPolling();
  };
  ws.onclose = () => {
    document.getElementById('wsHudDot').classList.remove('on');
    document.getElementById('wsHudLbl').textContent = 'OFFLINE';
    wsTimer = setTimeout(() => connect(), Math.min(3000*(wsRetry+1), 15000));
    wsRetry++;
  };
  ws.onerror = () => {};
  ws.onmessage = e => handleMsg(JSON.parse(e.data));
}

function send(obj) { if (ws && ws.readyState === 1) ws.send(JSON.stringify(obj)); }

/* ═══════════════════════════════════════
   MESSAGE HANDLER
═══════════════════════════════════════ */
function handleMsg(msg) {
  switch(msg.type) {
    case 'init':
      currentProvider = msg.provider || '';
      currentModel    = msg.model    || '';
      currentMode     = msg.mode || currentMode;
      updateModelBadge();
      refreshModelSelectors();
      if (msg.memory) renderMemory(msg.memory);
      if (msg.voice)  applyVoiceSettings(msg.voice);
      if (msg.wake_word !== undefined) {
        wakeWordEnabled = !!msg.wake_word;
        const wBtn = document.getElementById('wakeBtn');
        const wLbl = document.getElementById('wakeLbl');
        if (wBtn) { wBtn.textContent = wakeWordEnabled ? '🔒' : '🔓'; wBtn.style.color = wakeWordEnabled ? 'var(--gold)' : 'var(--tx2)'; }
        if (wLbl) wLbl.textContent = wakeWordEnabled ? 'WAKE ON' : 'WAKE';
      }
      const hudSession = document.getElementById('hudSession');
      if (hudSession) hudSession.textContent = msg.memory?.session_count || 1;
      buildKeysList();
      // Default always-listening: add green dot to mic button unless muted
      const initMuted = msg.muted === true;
      const initContinuous = msg.continuous_listening !== false;
      updateContinuousUI(initContinuous);
      const micBtnEl = document.getElementById('micBtn');
      if (micBtnEl) {
        if (!initMuted && initContinuous) micBtnEl.classList.add('always-on');
        micBtnEl.textContent = initMuted ? '🚫' : '🎙';
      }
      muted = initMuted;
      continuousEnabled = initContinuous;
      if (msg.state) setState(msg.state);
      updateModeUI();
      break;
    case 'wake_word_state':
      wakeWordEnabled = !!msg.enabled;
      { const wBtn = document.getElementById('wakeBtn'); const wLbl = document.getElementById('wakeLbl');
        if (wBtn) { wBtn.textContent = wakeWordEnabled ? '🔒' : '🔓'; wBtn.style.color = wakeWordEnabled ? 'var(--gold)' : 'var(--tx2)'; }
        if (wLbl) wLbl.textContent = wakeWordEnabled ? 'WAKE ON' : 'WAKE'; }
      break;
    case 'state':
      setState(msg.state);
      break;
    case 'transcript':
      removeTyping();
      if (msg.role !== 'assistant') {
        addMessage(msg.role, msg.text);
      }
      break;
    case 'stream_start':
      removeTyping();
      startStreamBubble();
      break;
    case 'token':
      appendStreamToken(msg.text);
      break;
    case 'stream_finalize':
      finalizeStreamBubble(msg.text);
      break;
    case 'partial':
      showTyping();
      break;
    case 'screenshot':
      showScreenshot(msg.data);
      break;
    case 'action':
      document.getElementById('actionResult').textContent =
        `[${msg.action}]\n→ ${String(msg.result).slice(0,200)}`;
      toast(`Tool: ${msg.action}`, 'cyan');
      if (msg.action === 'get_clipboard') {
        const preview = document.getElementById('clipboardPreview');
        if (preview) preview.value = String(msg.result || '');
      }
      break;
    case 'memory_updated':
      renderMemory(msg.memory);
      break;
    case 'key_saved':
      toast(`Key saved: ${msg.provider}`, 'green');
      if (msg.provider === 'elevenlabs') loadVoices();
      refreshModelSelectors();
      break;
    case 'voice_settings':
      applyVoiceSettings(msg);
      break;
    case 'model_changed':
      currentProvider = msg.provider;
      currentModel    = msg.model;
      updateModelBadge();
      syncModelSelectorsToCurrent();
      toast(`Model: ${msg.provider}/${msg.model}`, 'purple');
      break;
    case 'volume':
      setVolume(msg.level || 0);
      break;
    case 'stt_active': {
      const prov = msg.provider || 'auto';
      updateProviderPill('hudSTT', prov, false);
      const cascade = msg.cascade || [];
      const trail = document.getElementById('sttCascade');
      if (trail) {
        if (cascade.length > 1) {
          trail.textContent = cascade.join(' → ');
          trail.style.opacity = '1';
          clearTimeout(trail._fadeTimer);
          trail._fadeTimer = setTimeout(() => { trail.style.opacity = '0'; }, 5000);
        } else {
          trail.style.opacity = '0';
        }
      }
      break;
    }
    case 'tts_active': {
      const prov = msg.provider || 'auto';
      updateProviderPill('hudTTS', prov, false);
      break;
    }
    case 'pipeline_timing': {
      const parts = [];
      if (msg.stt_ms !== undefined) parts.push(`STT ${msg.stt_ms}ms`);
      if (msg.ttft_ms !== undefined) parts.push(`TTFT ${msg.ttft_ms}ms`);
      if (msg.tts_queue_ms !== undefined) parts.push(`TTS-Q ${msg.tts_queue_ms}ms`);
      if (msg.e2e_ms !== undefined) parts.push(`E2E ${msg.e2e_ms}ms`);
      if (parts.length) {
        const el = document.getElementById('pipelineTimingBar');
        if (el) { el.textContent = parts.join(' · '); el.style.display = 'block'; }
      }
      break;
    }
    case 'continuous_state': {
      const on = msg.enabled !== false;
      updateContinuousUI(on);
      const btn = document.getElementById('micBtn');
      if (btn) btn.classList.toggle('always-on', on && !muted);
      break;
    }
    case 'el_agent':
      updateElAgentStatus(msg.status, msg.message || msg.msg);
      break;
    case 'partial_transcript':
      showTranscriptBar(msg.text);
      break;
    case 'agent_orchestrator': {
      const icon = msg.icon || '🤖';
      const proj = msg.project ? `[${msg.project}] ` : '';
      const detail = msg.detail ? `\n${msg.detail}` : '';
      const link = msg.pr_url ? `\n🔗 ${msg.pr_url}` : '';
      addMessage('system', `${icon} AO ${proj}${msg.title}${detail}${link}`);
      toast(`${icon} ${msg.title}`, msg.event === 'ci-failed' ? 'red' : 'cyan');
      break;
    }
    case 'error':
      addMessage('system', '⚠ ' + msg.message);
      break;
  }
}

