/* ═══════════════════════════════════════
   BACKGROUND PARTICLE CANVAS
═══════════════════════════════════════ */
function startBgCanvas() {
  const canvas = document.getElementById('bgCanvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [], nodes = [], t = 0;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // Stars
  for (let i = 0; i < 200; i++) {
    particles.push({
      x: Math.random() * 2000, y: Math.random() * 1200,
      r: Math.random() * 1.5, speed: .02 + Math.random() * .06,
      opacity: .2 + Math.random() * .7, twinkle: Math.random() * 6.28
    });
  }
  // Neural nodes
  for (let i = 0; i < 28; i++) {
    nodes.push({
      x: 80 + Math.random() * (1760), y: 80 + Math.random() * (920),
      vx: (Math.random() - .5) * .25, vy: (Math.random() - .5) * .25,
      r: 1.5 + Math.random() * 2, pulse: Math.random() * 6.28
    });
  }

  // Nebula gradient (static, drawn once)
  function drawNebula() {
    const g1 = ctx.createRadialGradient(W*.3, H*.35, 0, W*.3, H*.35, W*.45);
    g1.addColorStop(0, 'rgba(29,78,216,.05)');
    g1.addColorStop(1, 'transparent');
    ctx.fillStyle = g1; ctx.fillRect(0,0,W,H);

    const g2 = ctx.createRadialGradient(W*.72, H*.6, 0, W*.72, H*.6, W*.35);
    g2.addColorStop(0, 'rgba(34,197,94,.03)');
    g2.addColorStop(1, 'transparent');
    ctx.fillStyle = g2; ctx.fillRect(0,0,W,H);

    const g3 = ctx.createRadialGradient(W*.5, H*.9, 0, W*.5, H*.9, W*.3);
    g3.addColorStop(0, 'rgba(34,197,94,.03)');
    g3.addColorStop(1, 'transparent');
    ctx.fillStyle = g3; ctx.fillRect(0,0,W,H);
  }

  function anim() {
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#020209';
    ctx.fillRect(0, 0, W, H);

    drawNebula();
    t += .004;

    // Stars
    particles.forEach(p => {
      p.twinkle += p.speed;
      const a = p.opacity * (.6 + .4 * Math.sin(p.twinkle));
      ctx.beginPath();
      ctx.arc((p.x % W + t*8) % W, (p.y + t*2) % H, p.r, 0, 6.28);
      ctx.fillStyle = `rgba(212,212,255,${a})`;
      ctx.fill();
    });

    // Neural nodes
    nodes.forEach(n => {
      n.x += n.vx; n.y += n.vy;
      if (n.x < 0 || n.x > W) n.vx *= -1;
      if (n.y < 0 || n.y > H) n.vy *= -1;
      n.pulse += .015;
    });

    // Neural connections
    const active = state !== 'idle';
    nodes.forEach((a2, i) => {
      nodes.slice(i+1).forEach(b => {
        const dx = a2.x - b.x, dy = a2.y - b.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        const maxDist = active ? 220 : 160;
        if (dist < maxDist) {
          const alpha = (1 - dist/maxDist) * (active ? .18 : .07);
          ctx.beginPath();
          ctx.moveTo(a2.x, a2.y);
          ctx.lineTo(b.x, b.y);
          const c = state === 'thinking' ? `rgba(245,158,11,${alpha})` :
                    state === 'speaking' ? `rgba(16,185,129,${alpha})` :
                    state === 'listening' || state === 'recording' ? `rgba(6,182,212,${alpha})` :
                    `rgba(29,78,216,${alpha})`;
          ctx.strokeStyle = c;
          ctx.lineWidth = .6;
          ctx.stroke();
        }
      });

      // Node dots
      const pulse = .5 + .5 * Math.sin(a2.pulse);
      const baseAlpha = active ? .4 + .3*pulse : .15 + .1*pulse;
      ctx.beginPath();
      ctx.arc(a2.x, a2.y, a2.r * (active ? 1 + .4*pulse : 1), 0, 6.28);
      const nc = state === 'thinking' ? `rgba(251,191,36,${baseAlpha})` :
                 state === 'speaking' ? `rgba(52,211,153,${baseAlpha})` :
                 `rgba(59,130,246,${baseAlpha})`;
      ctx.fillStyle = nc;
      ctx.fill();
    });

    requestAnimationFrame(anim);
  }
  anim();
}

