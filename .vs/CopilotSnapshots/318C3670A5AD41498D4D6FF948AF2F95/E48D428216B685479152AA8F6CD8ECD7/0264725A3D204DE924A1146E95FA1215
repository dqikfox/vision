function quickAction(name) {
  send({ type:'execute_tool', tool:name, args:{} });
  document.getElementById('actionResult').textContent = `▶ Running ${name}…`;
}
function promptAction(name, label) {
  const p = prompt(label || `Parameter for ${name}:`);
  if (p === null) return;
  const argMap = {
    run_command:{command:p}, type_text:{text:p}, press_key:{key:p},
    focus_window:{title:p}, list_files:{path:p}, read_file:{path:p},
    browser_open:{url:p}, browser_click:{selector:p}, browser_extract:{selector:p},
  };
  const args = argMap[name] || {value:p};
  send({ type:'execute_tool', tool:name, args });
  document.getElementById('actionResult').textContent = `▶ ${name}: ${p.slice(0,60)}`;
}
function launchApp(app) {
  send({ type:'execute_tool', tool:'run_command', args:{command:`start ${app}`} });
  toast(`Launching ${app}…`);
}

