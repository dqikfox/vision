/* ═══════════════════════════════════════
   STATE MACHINE
═══════════════════════════════════════ */
const stateLabels = {
  idle:'◆ SOVEREIGN ONLINE', thinking:'◈ FORESEEING…',
  speaking:'◉ DECREEING…', listening:'◎ RECEIVING TRIBUTE…',
  recording:'● CAPTURING SIGNAL…', muted:'○ SILENCED'
};
const stateColors = {
  idle:'var(--p2)', thinking:'var(--gold)', speaking:'var(--g2)',
  listening:'var(--c2)', recording:'var(--c)', muted:'var(--dim)'
};
function setState(s) {
  state = s;
  setOrbState(s);
  const heroShell = document.getElementById('heroShell');
  if (heroShell) heroShell.dataset.runtimeState = s;
  const lbl = document.getElementById('stateLabel');
  lbl.textContent = stateLabels[s] || s.toUpperCase();
  lbl.style.color = stateColors[s] || 'var(--p2)';
  if (s === 'thinking') showTyping(); else removeTyping();
  // Transcript bar: keep visible during thinking (shows what was heard), hide on speaking/listening
  if (s === 'listening' || s === 'speaking') hideTranscriptBar();
  // Barge-in hint
  const barge = document.getElementById('bargeInHint');
  if (barge) barge.style.display = s === 'speaking' ? 'block' : 'none';
  // Latency tracking
  if (s === 'recording') { listenTimestamp = Date.now(); latencyShown = false; }
  if (s === 'speaking' && listenTimestamp && !latencyShown) {
    latencyShown = true;
    showLatency(Date.now() - listenTimestamp);
    listenTimestamp = null;
  }
  // Provider pill pulse animations
  const sttPill = document.getElementById('hudSTT');
  const ttsPill = document.getElementById('hudTTS');
  if (sttPill) sttPill.classList.toggle('p-active', s === 'recording');
  if (ttsPill) ttsPill.classList.toggle('p-active', s === 'speaking');
  // Mic button recording glow
  const micBtn = document.getElementById('micBtn');
  if (micBtn) micBtn.classList.toggle('recording-glow', s === 'recording' || s === 'listening');
  updateHeroDeck();
}
function updateProviderPill(elemId, provider, active) {
  const el = document.getElementById(elemId);
  if (!el) return;
  const labels = { elevenlabs: 'ELEVENLABS', groq: 'GROQ', local: 'LOCAL', 'local-onecore': 'ONECORE', 'local-sapi': 'SAPI', auto: 'AUTO' };
  const classes = { elevenlabs: 'p-elevenlabs', groq: 'p-groq', local: 'p-local', 'local-onecore': 'p-local', 'local-sapi': 'p-local', auto: 'p-auto' };
  el.textContent = labels[provider] || provider.toUpperCase();
  el.className = 'provider-pill ' + (classes[provider] || 'p-auto') + (active ? ' p-active' : '');
}
function voiceProviderLabel(provider) {
  const labels = { auto:'Auto', elevenlabs:'ElevenLabs', local:'Local Windows' };
  return labels[provider] || provider.toUpperCase();
}
function resolveVoiceProvider(preferred = voiceSettings.preferred_tts || 'auto') {
  if (preferred === 'elevenlabs' && voiceCatalog.elevenlabs?.available) return 'elevenlabs';
  if (preferred === 'local') return 'local';
  return voiceCatalog.elevenlabs?.available ? 'elevenlabs' : 'local';
}
function getVoiceEntry(provider = resolveVoiceProvider()) {
  const selectedProvider = provider === 'elevenlabs' ? 'elevenlabs' : 'local';
  const voices = voiceCatalog[selectedProvider]?.voices || [];
  if (!voices.length) return null;
  if (selectedProvider === 'elevenlabs') {
    return voices.find((voice) => voice.id === voiceSettings.tts_voice_id) || voices[0];
  }
  return voices.find((voice) => String(voice.index) === String(voiceSettings.tts_voice_idx ?? 0)) || voices[0];
}
function updateVoiceProviderSummary(preferred = voiceSettings.preferred_tts || 'auto') {
  const resolved = resolveVoiceProvider(preferred);
  const badge = document.getElementById('voiceProviderBadge');
  const title = document.getElementById('voiceProviderTitle');
  const note = document.getElementById('voiceProviderNote');
  const hint = document.getElementById('voiceLoadHint');
  const providerMeta = voiceCatalog[resolved] || { label: voiceProviderLabel(resolved), voices: [] };
  const providerVoices = providerMeta.voices || [];
  const displayLabel = preferred === 'auto'
    ? `AUTO → ${voiceProviderLabel(resolved).toUpperCase()}`
    : preferred !== resolved
      ? `${voiceProviderLabel(preferred).toUpperCase()} → ${voiceProviderLabel(resolved).toUpperCase()}`
      : voiceProviderLabel(preferred).toUpperCase();
  if (badge) {
    updateProviderPill('voiceProviderBadge', resolved, false);
    badge.textContent = displayLabel;
  }
  if (title) title.textContent = `${providerMeta.label || voiceProviderLabel(resolved)} VOICES`;
  if (note) {
    note.textContent = preferred === 'auto'
      ? `Auto will currently use ${providerMeta.label || voiceProviderLabel(resolved)} and show only matching voices.`
      : `Showing only voices that work with ${providerMeta.label || voiceProviderLabel(resolved)}.`;
  }
  if (hint) {
    hint.textContent = providerVoices.length
      ? `${providerVoices.length} ${providerMeta.label || voiceProviderLabel(resolved)} voices ready.`
      : `No ${providerMeta.label || voiceProviderLabel(resolved)} voices available.`;
  }
}
function renderVoiceOptions(preferred = voiceSettings.preferred_tts || 'auto') {
  const container = document.getElementById('voiceRadios');
  const label = document.getElementById('voice-label');
  if (!container) return;
  const resolved = resolveVoiceProvider(preferred);
  const providerMeta = voiceCatalog[resolved] || { label: voiceProviderLabel(resolved), voices: [] };
  const voices = providerMeta.voices || [];
  if (label) {
    label.textContent = resolved === 'elevenlabs' ? '🗣 ELEVENLABS VOICES' : '🗣 LOCAL WINDOWS VOICES';
  }
  updateVoiceProviderSummary(preferred);
  if (!voices.length) {
    container.innerHTML = '<div class="r-opt on" data-provider="local" data-index="0" data-voice-id="">NO VOICES</div>';
    return;
  }
  container.innerHTML = voices.map((voice) => {
    const voiceProvider = resolved === 'elevenlabs' ? 'elevenlabs' : 'local';
    const dataVal = voiceProvider === 'elevenlabs' ? escAttr(voice.id) : escAttr(String(voice.index));
    const voiceId = voiceProvider === 'elevenlabs' ? escAttr(voice.id) : '';
    const voiceIndex = voiceProvider === 'local' ? escAttr(String(voice.index)) : '';
    return `<div class="r-opt" data-val="${dataVal}" data-provider="${voiceProvider}" data-index="${voiceIndex}" data-voice-id="${voiceId}" onclick="selectRadio(this,'voiceRadios')" role="radio" aria-checked="false" tabindex="0">${escHtml(voice.name)}</div>`;
  }).join('');
  const selected = getVoiceEntry(resolved);
  const match = resolved === 'elevenlabs'
    ? container.querySelector(`[data-voice-id="${CSS.escape(selected?.id || '')}"]`)
    : container.querySelector(`[data-index="${CSS.escape(String(selected?.index ?? ''))}"]`);
  const first = container.querySelector('.r-opt');
  if (match) match.classList.add('on');
  else if (first) first.classList.add('on');
}
function updateHeroDeck() {
  const providerRuntime = document.getElementById('heroProviderRuntime');
  const modelRuntime = document.getElementById('heroModelRuntime');
  const voiceRuntime = document.getElementById('heroVoiceRuntime');
  const voiceProvider = document.getElementById('heroVoiceProvider');
  const voiceSelection = document.getElementById('heroVoiceSelection');
  const heroState = document.getElementById('heroStateRuntime');
  const resolvedVoiceProvider = resolveVoiceProvider();
  const voice = getVoiceEntry(resolvedVoiceProvider);
  if (providerRuntime) providerRuntime.textContent = providerLabel(currentProvider);
  if (modelRuntime) modelRuntime.textContent = currentModel || 'No model selected';
  if (voiceRuntime) voiceRuntime.textContent = voiceProviderLabel(voiceSettings.preferred_tts || 'auto');
  if (voiceProvider) {
    voiceProvider.textContent = voiceSettings.preferred_tts === 'auto'
      ? `AUTO → ${voiceProviderLabel(resolvedVoiceProvider)}`
      : voiceSettings.preferred_tts !== resolvedVoiceProvider
        ? `${voiceProviderLabel(voiceSettings.preferred_tts).toUpperCase()} → ${voiceProviderLabel(resolvedVoiceProvider).toUpperCase()}`
        : voiceProviderLabel(voiceSettings.preferred_tts || resolvedVoiceProvider).toUpperCase();
  }
  if (voiceSelection) voiceSelection.textContent = voice ? voice.name : 'Awaiting voice catalog…';
  if (heroState) heroState.textContent = stateLabels[state] || 'SOVEREIGN ONLINE';
}
function setVolume(v) {
  setOrbVolume(v);
  const N = 16;
  const baseH = 28;
  for (let i = 0; i < N; i++) {
    const bar = document.getElementById('eq' + i);
    if (!bar) continue;
    // Natural frequency band falloff: center bands louder
    const bandFactor = 0.5 + 0.5 * Math.sin((i / (N-1)) * Math.PI);
    const noise = 0.4 + 0.6 * Math.abs(Math.sin(Date.now() * 0.003 + i * 1.3));
    const heightPct = v > 0.02 ? Math.max(5, v * 100 * bandFactor * noise) : (1 + 2 * Math.abs(Math.sin(Date.now()*0.001+i)));
    bar.style.height = Math.min(heightPct, 98) + '%';
    bar.className = 'eq-bar' + (heightPct > 70 ? ' peak' : heightPct > 45 ? ' hi' : '');
  }
}

