function appendStreamToken(text) {
  const bubble = document.getElementById('streamBubble');
  if (!bubble) { startStreamBubble(); return appendStreamToken(text); }
  bubble.textContent += text;
  const c = document.getElementById('consoleMessages');
  c.scrollTop = c.scrollHeight;
}

function finalizeStreamBubble(text) {
  const bubble = document.getElementById('streamBubble');
  if (bubble) {
    // Clean the final text (strip any tool call artifacts)
    bubble.textContent = text.trim();
    bubble.removeAttribute('id'); // detach id so next stream starts fresh
  }
  streamEl = null;
