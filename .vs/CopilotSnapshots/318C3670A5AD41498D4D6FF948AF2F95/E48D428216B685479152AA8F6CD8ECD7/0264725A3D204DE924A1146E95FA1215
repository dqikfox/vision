}
function removeTyping() { if (typingEl) { typingEl.remove(); typingEl = null; } }

function startStreamBubble() {
  if (streamEl) return; // already streaming
  const console_ = document.getElementById('consoleMessages');
  streamEl = document.createElement('div');
  streamEl.className = 'msg msg-assistant';
  streamEl.innerHTML = '<div class="msg-avatar ai">⬡</div><div><div class="msg-role">VISION</div><div class="msg-bubble" id="streamBubble"></div></div>';
  console_.appendChild(streamEl);
