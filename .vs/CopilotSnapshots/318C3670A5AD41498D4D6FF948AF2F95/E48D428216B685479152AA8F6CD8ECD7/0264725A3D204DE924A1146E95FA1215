}

function scrollPage(dir) {
  const key = dir === 'up' ? 'pageup' : 'pagedown';
  send({ type:'execute_tool', tool:'press_key', args:{ key } });
}

async function readClipboard() {
  send({ type:'execute_tool', tool:'get_clipboard', args:{} });
  document.getElementById('actionResult').textContent = '▶ Reading clipboard…';
