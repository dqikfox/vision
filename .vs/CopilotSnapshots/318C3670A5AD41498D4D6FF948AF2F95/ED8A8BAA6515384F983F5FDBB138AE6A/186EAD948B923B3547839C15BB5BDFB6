root = true

# Default settings for all files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

# Python files - Vision backend and MCP servers
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# HTML - Vision GUI interfaces  
[*.html]
indent_style = space
indent_size = 2
max_line_length = 120

# CSS - Inline and external styles
[*.css]
indent_style = space
indent_size = 2

# JSON, YAML, TOML - Configuration files
[*.{json,yml,yaml,toml}]
indent_style = space
indent_size = 2

# JavaScript/TypeScript
[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size = 2
max_line_length = 120

# PowerShell scripts - Vision launchers
[*.ps1]
indent_style = space
indent_size = 4
end_of_line = crlf

# Markdown - Documentation
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Batch/Shell scripts
[*.{bat,sh}]
end_of_line = lf
