{
    // ── Disable automatic npm install ───────────────────────────────────────
    "npm.autoInstall": false,
    "typescript.disableAutomaticTypeAcquisition": true,

    // ── Python: Ruff as formatter + linter ──────────────────────────────────
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.format.args": ["--line-length=120"],

    // ── Pyright / Pylance ────────────────────────────────────────────────────
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.autoSearchPaths": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": false,
    "python.analysis.inlayHints.callArgumentNames": "partial",
    "python.analysis.extraPaths": ["c:\\project\\vision"],

    // ── Python interpreter ────────────────────────────────────────────────────
    "python.defaultInterpreterPath": "C:\\Users\\CHANN0$\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe",

    // ── Flake8 ────────────────────────────────────────────────────────────────
    "flake8.interpreter": ["C:\\Users\\CHANN0$\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe"],
    "flake8.args": ["--config=c:\\project\\vision\\.flake8"],

    // ── Pylint ────────────────────────────────────────────────────────────────
    "pylint.interpreter": ["C:\\Users\\CHANN0$\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe"],
    "pylint.args": [
        "--disable=W0611,C0413",
        "--generated-members=PIL.Image.Resampling.*,PIL.Image.LANCZOS"
    ],

    // ── Mypy ─────────────────────────────────────────────────────────────────
    "mypy-type-checker.interpreter": ["C:\\Users\\CHANN0$\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe"],
    "mypy-type-checker.args": ["--ignore-missing-imports", "--no-strict-optional"],

    // ── isort ─────────────────────────────────────────────────────────────────
    "isort.interpreter": ["C:\\Users\\CHANN0$\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe"],
    "isort.args": ["--profile", "black", "--line-length", "120"],

    // ── Testing ───────────────────────────────────────────────────────────────
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": ["c:\\project\\vision", "-v", "--tb=short"],
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "windsurf": true,
        "cursor-global": true,
        "cursor-workspace": true
    },
    "github.copilot.chat.agent.runInWorkspace": true,
    "github.copilot.chat.agent.workspace": "C:/project/vision",

    // ── GitHub Copilot ────────────────────────────────────────────────────────
    "github.copilot.enable": {
        "*": true,
        "yaml": true,
        "markdown": true,
        "plaintext": true
    },
    "github.copilot.editor.enableAutoCompletions": true,
    "github.copilot.chat.followUps": "always",
    "github.copilot.chat.localeOverride": "en",
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.chat.codeGeneration.instructions": [
        { "file": ".github/copilot-instructions.md" },
        { "file": ".github/copilot-conventions.md" }
    ],
    "github.copilot.chat.customOAIModels": {
        "openclaw/default": {
            "name": "OpenClaw Default",
            "url": "https://msi.tail886dbb.ts.net/v1",
            "toolCalling": true,
            "vision": false,
            "maxInputTokens": 128000,
            "maxOutputTokens": 8192
        }
    },

    // ── GitLens ───────────────────────────────────────────────────────────────
    "gitlens.codeLens.enabled": true,
    "gitlens.currentLine.enabled": true,
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.blame.highlight.enabled": true,
    "gitlens.graph.layout": "editor",
    "gitlens.ai.model": "vscode",

    // ── Error Lens ────────────────────────────────────────────────────────────
    "errorLens.enabled": true,
    "errorLens.enabledDiagnosticLevels": ["error", "warning", "info"],
    "errorLens.followCursor": "activeLine",
    "errorLens.delay": 200,

    // ── Todo Tree ─────────────────────────────────────────────────────────────
    "todo-tree.general.tags": ["TODO", "FIXME", "HACK", "BUG", "NOTE", "PERF", "SECURITY"],
    "todo-tree.highlights.defaultHighlight": {
        "foreground": "#ffffff",
        "background": "#1d4ed8",
        "icon": "check",
        "type": "text"
    },
    "todo-tree.highlights.customHighlight": {
        "FIXME": { "background": "#dc2626", "icon": "flame" },
        "BUG":   { "background": "#dc2626", "icon": "bug" },
        "SECURITY": { "background": "#7c3aed", "icon": "shield" },
        "PERF":  { "background": "#d97706", "icon": "zap" }
    },
    "todo-tree.tree.showCountsInTree": true,

    // ── Better Comments ───────────────────────────────────────────────────────
    "better-comments.tags": [
        { "tag": "!", "color": "#ff4757", "strikethrough": false, "underline": false, "backgroundColor": "transparent", "bold": true, "italic": false },
        { "tag": "?", "color": "#3b82f6", "strikethrough": false, "underline": false, "backgroundColor": "transparent", "bold": false, "italic": false },
        { "tag": "//", "color": "#334155", "strikethrough": true, "underline": false, "backgroundColor": "transparent", "bold": false, "italic": false },
        { "tag": "todo", "color": "#fbbf24", "strikethrough": false, "underline": false, "backgroundColor": "transparent", "bold": false, "italic": false },
        { "tag": "*", "color": "#22c55e", "strikethrough": false, "underline": false, "backgroundColor": "transparent", "bold": true, "italic": false }
    ],

    // ── REST Client ───────────────────────────────────────────────────────────
    "rest-client.environmentVariables": {
        "$shared": {
            "vision_base": "http://localhost:8765",
            "ollama_base": "http://localhost:11434"
        }
    },
    "rest-client.previewOption": "full",

    // ── Docker ────────────────────────────────────────────────────────────────
    "docker.showStartPage": false,

    // ── Ollama extensions ─────────────────────────────────────────────────────
    "ollama-copilot.model": "qikfox/ultronv1",
    "ollama-copilot.autocompleteEnabled": true,
    "ollama-copilot.chatModel": "qikfox/ultronv1",

    // ── Gemini Code Assist ────────────────────────────────────────────────────
    "geminicodeassist.outlines.automaticOutlineGeneration": true,
    "geminicodeassist.project": "",

    // ── Continue.dev ──────────────────────────────────────────────────────────
    "continue.enableTabAutocomplete": true,

    // ── CodeMetrics ───────────────────────────────────────────────────────────
    "codemetrics.basics.ComplexityLevelExtreme": 15,
    "codemetrics.basics.ComplexityLevelHigh": 10,
    "codemetrics.basics.ComplexityLevelNormal": 5,
    "codemetrics.basics.ComplexityLevelLow": 1,
    "codemetrics.basics.EnabledForPython": true,

    // ── Bookmarks ─────────────────────────────────────────────────────────────
    "bookmarks.saveBookmarksInProject": true,
    "bookmarks.useWorkaroundForFormatters": true,

    // ── Path Intellisense ─────────────────────────────────────────────────────
    "path-intellisense.autoSlashAfterDirectory": true,
    "path-intellisense.extensionOnImport": true,
    "path-intellisense.showHiddenFiles": true,

    // ── Indent Rainbow ────────────────────────────────────────────────────────
    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 2,

    // ── Color Highlight ───────────────────────────────────────────────────────
    "color-highlight.enable": true,
    "color-highlight.markerType": "underline",

    // ── Spell Checker ─────────────────────────────────────────────────────────
    "cSpell.enabled": true,
    "cSpell.language": "en",
    "cSpell.words": [
        "CHANN", "pyautogui", "pytesseract", "pyttsx", "pywin", "pynvml",
        "pyperclip", "pygetwindow", "sounddevice", "uvicorn", "fastapi",
        "websockets", "elevenlabs", "ollama", "anthropic", "deepseek",
        "groq", "mistral", "gemini", "openai", "asyncio", "noqa",
        "LANCZOS", "Resampling", "barge", "VAD", "STT", "TTS",
        "ULTRON", "VISION", "HIVE", "APEX", "dqikfox",
        "modelcontextprotocol", "shapefile"
    ],
    "cSpell.ignorePaths": [
        ".brain", ".archon", ".mypy_cache", ".pw_profile",
        "memory.json", "chat_events.log"
    ],

    // ── Markdown Lint ─────────────────────────────────────────────────────────
    "markdownlint.config": {
        "MD013": false,
        "MD033": false,
        "MD041": false
    },

    // ── YAML ──────────────────────────────────────────────────────────────────
    "yaml.validate": true,
    "yaml.hover": true,
    "yaml.completion": true,
    "yaml.schemas": {
        "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
    },

    // ── dotenv ────────────────────────────────────────────────────────────────
    "dotenv.enableAutocloaking": true,

    // ── Output Formatter ──────────────────────────────────────────────────────
    "output-formatter.enable": true,

    // ── Windows Terminal ──────────────────────────────────────────────────────
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.env.windows": {
        "PYTHONPATH": "c:\\project\\vision",
        "VISION_BASE_URL": "http://localhost:8765"
    },

    // ── Editor ───────────────────────────────────────────────────────────────
    "editor.formatOnSave": true,
    "editor.rulers": [120],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.renderWhitespace": "boundary",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.minimap.enabled": true,
    "editor.minimap.renderCharacters": false,
    "editor.stickyScroll.enabled": true,
    "editor.linkedEditing": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.enabled": true,
    "editor.wordWrap": "off",

    // ── Files ────────────────────────────────────────────────────────────────
    "files.eol": "\n",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/htmlcov": true,
        "**/.mypy_cache": true,
        "**/openJdk-25": true
    },
    "files.associations": {
        "*.env": "dotenv",
        "*.ps1": "powershell",
        "Modelfile*": "dockerfile",
        "*.agent.md": "markdown",
        "SKILL.md": "markdown"
    },

    // ── Search ────────────────────────────────────────────────────────────────
    "search.exclude": {
        "**/__pycache__": true,
        "**/.mypy_cache": true,
        "**/.brain": true,
        "**/openJdk-25": true,
        "**/.pw_profile": true
    },

    // ── Git ───────────────────────────────────────────────────────────────────
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.decorations.enabled": true,

    // ── Workbench ─────────────────────────────────────────────────────────────
    "workbench.iconTheme": "material-icon-theme",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.enablePreviewFromCodeNavigation": true,
    "workbench.startupEditor": "none",
    "workbench.colorTheme": "Hacker",

