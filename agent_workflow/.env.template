# Vision Content Collaboration Workflow Environment
# Copy this file to .env and fill in your values

# Microsoft Foundry Configuration
FOUNDRY_PROJECT_ENDPOINT=https://your-project.openai.azure.com/
# Find this in Azure OpenAI / Foundry under your resource's Deployments blade.
FOUNDRY_MODEL_DEPLOYMENT_NAME=<YOUR_DEPLOYMENT_NAME>

# Azure Authentication
# Uses DefaultAzureCredential - ensure you're logged in with:
# az login

# Workflow Configuration
WORKFLOW_MAX_ITERATIONS=3
# Integer between 1 and 1000. Invalid values fall back to 3.
WORKFLOW_OUTPUT_DIR=./outputs
# Relative paths are allowed. The workflow creates the directory automatically.

# Optional: Override default behavior. See README.md for usage details.
# Allowed values: documentation, blog, email, social, report
# Controls the generated output format and structure.
# WORKFLOW_DEFAULT_CONTENT_TYPE=documentation
# Allowed values: professional, casual, technical, friendly, persuasive
# Controls the style and voice used by the writer agent.
# WORKFLOW_DEFAULT_TONE=professional
