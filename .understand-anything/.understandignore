# *.env
# *.pyc
# *.pyo
# *.pyd
# .Python
# *.egg-info/
# .coverage
# htmlcov/
# *.txt.bak
# overlay_err.txt
# startup_err.txt
# startup_out.txt
# memory.json
# .brain/
# Thumbs.db
# .DS_Store
# .vscode/settings.json
# !uv.lock
# .archon/artifacts/
