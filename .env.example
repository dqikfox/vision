# Vision Environment Configuration
# Copy this file to .env and fill in your API keys

# GitHub Models (via Azure) - Required for GitHub provider
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenAI - Optional, for OpenAI provider
OPENAI_API_KEY=your_openai_key_here

# Azure-hosted OpenAI-compatible endpoint - Optional, used by scripts/invoke_azure_openai_chat.py
AZURE_OPENAI_BASE_URL=https://your-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_KEY=your_azure_openai_key_here

# ElevenLabs - Optional, for voice features
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Groq - Optional, for fast inference
GROQ_API_KEY=your_groq_key_here

# Anthropic - Optional, for Claude models
ANTHROPIC_API_KEY=your_anthropic_key_here

# DeepSeek - Optional
DEEPSEEK_API_KEY=your_deepseek_key_here

# Mistral - Optional
MISTRAL_API_KEY=your_mistral_key_here

# Gemini - Optional
GEMINI_API_KEY=your_gemini_key_here

# xAI (Grok) - Optional
XAI_API_KEY=your_xai_key_here
