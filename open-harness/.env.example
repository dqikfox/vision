# Vision Open Harness Environment Configuration
# Copy this file to .env and customize as needed

# Model provider: ollama | openai
MODEL_PROVIDER=ollama

# Unified model name (takes precedence when set)
MODEL_NAME=kimi-k2.5:cloud

# Optional comma-separated fallbacks used when provider/model returns transient errors
MODEL_FALLBACKS=qwen2.5-coder:7b,llama3.1:8b

# Ollama Configuration
# Host where Ollama is running (use 127.0.0.1 for local machine)
OLLAMA_HOST=0.0.0.0

# Ollama API port
OLLAMA_PORT=11434

# Optional auth token (OpenAI-compatible clients require a value)
OLLAMA_API_KEY=ollama

# Default model to use (must be available in Ollama)
OLLAMA_MODEL=kimi-k2.5:cloud

# OpenAI Configuration (used when MODEL_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1

# Vision MCP Server Configuration
# Base URL where Vision FastAPI server is running
VISION_BASE_URL=http://localhost:8765

# Alternative: Use Vision over LAN from another device
# VISION_BASE_URL=http://your-pc-ip:8765

# MCP server process options
VISION_MCP_PYTHON=python
VISION_MCP_SCRIPT=..\vision_mcp_server.py
# keep screenshot base64 out of LLM context by default
VISION_MCP_INCLUDE_SCREENSHOT_B64=0

# Agent runtime
AGENT_MAX_STEPS=30
AGENT_CONTEXT_WINDOW=128000
AGENT_RESERVED_TOKENS=16000

# Session persistence
SESSION_PERSIST=true
SESSION_DIR=.sessions
SESSION_ID=default

# Telemetry
TELEMETRY_ENABLED=true
TELEMETRY_PATH=.logs/vision-agent.jsonl

# Approval policy file
POLICY_PATH=.openharness-policy.json

# Safety
# true = auto-approve non-read-only tool calls (dangerous)
VISION_AUTO_APPROVE_UNSAFE=false

# OpenAI/Anthropic/Groq Keys (optional - if you want to switch providers)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
